# CyberCom Platform - Environment Variables Template
# Copy to .env and fill real values. NEVER commit .env to git.
# OCI Region: il-jerusalem-1 | VM: 158.178.130.4

ENVIRONMENT=production
IMAGE_TAG=latest
LOG_LEVEL=INFO

# Database
POSTGRES_DB=cybercom
POSTGRES_USER=cybercom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://cybercom:CHANGE_ME@postgres:5432/cybercom

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# Security
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY_MIN_50_CHARS
ALLOWED_HOSTS=api.cy-com.com,www.cy-com.com,158.178.130.4,localhost
CORS_ORIGINS=https://www.cy-com.com,https://health.cy-com.com,https://provider.cy-com.com

# OCI
OCI_REGION=il-jerusalem-1
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaaaaaae3kk67errd7y65ua4ers3hrbe5jwt3er6bcdcur5aqmwu5on7oya
OCI_COMPARTMENT_OCID=ocid1.tenancy.oc1..aaaaaaaae3kk67errd7y65ua4ers3hrbe5jwt3er6bcdcur5aqmwu5on7oya
OCI_USER_OCID=CHANGE_ME_USER_OCID
OCI_FINGERPRINT=CHANGE_ME_API_KEY_FINGERPRINT
OCI_REGISTRY=il-jerusalem-1.ocir.io
OCI_TENANCY_NAMESPACE=CHANGE_ME_NAMESPACE

# Domains
DOMAIN_NAME=cy-com.com
API_URL=https://api.cy-com.com
WEBSITE_URL=https://www.cy-com.com

# Email
EMAIL_HOST=smtp.outlook.com
EMAIL_PORT=587
EMAIL_USER=CHANGE_ME_EMAIL
EMAIL_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
DEFAULT_FROM_EMAIL=noreply@cy-com.com

# Monitoring
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
SLACK_WEBHOOK_URL=CHANGE_ME_SLACK_WEBHOOK
