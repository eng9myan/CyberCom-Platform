# CyberCom Platform — Environment Variables Reference
# Copy to .env.local or inject via Kubernetes secrets / Vault
# Never commit real values to source control.

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-min-50-chars-random
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,cybercom.io
ENVIRONMENT=development
APP_VERSION=0.1.0

# ── Database (PostgreSQL 16) ─────────────────────────────────────────────────
DB_NAME=cybercom_dev
DB_USER=cybercom_app
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# ── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIME_LIMIT=300

# ── Kafka (ADR-0004) ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ── CyIdentity / Keycloak (ADR-0005) ─────────────────────────────────────────
CYIDENTITY_ISSUER=http://localhost:8080/realms/cybercom
CYIDENTITY_JWKS_URI=http://localhost:8080/realms/cybercom/protocol/openid-connect/certs
CYIDENTITY_CLIENT_ID=cybercom-backend
JWT_PUBLIC_KEY=

# ── PHI field-level encryption (HIPAA 164.312(a)(2)(iv)) ─────────────────────
# REQUIRED when DEBUG=False -- platform/common/security/encryption.py refuses
# to start (not silently fall back to a dev key) without this set. Generate
# with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHI_FIELD_ENCRYPTION_KEY=

# ── Observability (ADR-0009) ─────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cybercom-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── API ──────────────────────────────────────────────────────────────────────
API_PAGE_SIZE=25
