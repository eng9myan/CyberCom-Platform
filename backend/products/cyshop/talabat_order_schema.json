{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TalabatOrderWebhookPayload",
  "type": "object",
  "required": [
    "order_uuid",
    "short_code",
    "merchant_id",
    "currency",
    "payment_method",
    "delivery_type",
    "status",
    "timestamps",
    "items",
    "pricing"
  ],
  "properties": {
    "order_uuid": {
      "type": "string",
      "format": "uuid",
      "description": "Unique order transaction identifier."
    },
    "short_code": {
      "type": "string",
      "maxLength": 8,
      "description": "Short code printed on the receipt for riders."
    },
    "merchant_id": {
      "type": "string",
      "description": "Talabat store branch identifier."
    },
    "currency": {
      "type": "string",
      "enum": ["SAR", "JOD"],
      "description": "Active currency token."
    },
    "payment_method": {
      "type": "string",
      "enum": ["CREDIT_CARD", "CASH", "DIGITAL_WALLET"],
      "description": "Payment type."
    },
    "delivery_type": {
      "type": "string",
      "enum": ["DELIVERY", "PICKUP"],
      "description": "Dispatch method."
    },
    "status": {
      "type": "string",
      "enum": ["RECEIVED", "ACCEPTED", "COOKING", "READY_FOR_PICKUP", "DISPATCHED", "CANCELLED"],
      "description": "Order progression status."
    },
    "timestamps": {
      "type": "object",
      "required": ["created_at", "delivery_eta"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "delivery_eta": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sku", "name", "quantity", "unit_price", "total_price"],
        "properties": {
          "sku": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "unit_price": {
            "type": "number",
            "minimum": 0
          },
          "total_price": {
            "type": "number",
            "minimum": 0
          },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sku", "name", "price"],
              "properties": {
                "sku": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "price": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    },
    "customer": {
      "type": "object",
      "required": ["first_name", "phone"],
      "properties": {
        "first_name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "delivery_address": {
          "type": "object",
          "required": ["street", "city"],
          "properties": {
            "street": {
              "type": "string"
            },
            "building": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            }
          }
        }
      }
    },
    "pricing": {
      "type": "object",
      "required": ["subtotal", "tax_amount", "delivery_fee", "commission_fee", "total"],
      "properties": {
        "subtotal": {
          "type": "number",
          "minimum": 0
        },
        "tax_amount": {
          "type": "number",
          "minimum": 0
        },
        "delivery_fee": {
          "type": "number",
          "minimum": 0
        },
        "commission_fee": {
          "type": "number",
          "minimum": 0
        },
        "discount_amount": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "rider": {
      "type": "object",
      "required": ["name", "phone"],
      "properties": {
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        }
      }
    }
  }
}
