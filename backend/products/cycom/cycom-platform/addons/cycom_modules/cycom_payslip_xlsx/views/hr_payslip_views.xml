<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_hr_payslip_form_xlsx_export" model="ir.ui.view">
        <field name="name">hr.payslip.form.xlsx.export</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_export_payslip']" position="attributes">
                <attribute name="string">Export XLSX</attribute>
                <attribute name="invisible">not line_ids</attribute>
                <attribute name="groups">hr_payroll.group_hr_payroll_user</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_hr_payslip_list_xlsx_export" model="ir.ui.view">
        <field name="name">hr.payslip.list.xlsx.export</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/header/button[@name='action_print_payslip']" position="after">
                <button string="Export XLSX" name="action_export_payslip" type="object"/>
            </xpath>
        </field>
    </record>
</cycom>
