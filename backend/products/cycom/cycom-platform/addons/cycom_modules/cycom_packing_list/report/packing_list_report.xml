<cycom>
  <!-- Report 1: Packing List (NO dates) -->
  <record id="action_report_packing_list" model="ir.actions.report">
    <field name="name">Packing List</field>
    <field name="model">account.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">cycom_packing_list.packing_list_template</field>
    <field name="report_file">cycom_packing_list.packing_list_template</field>
    <field name="print_report_name">'Packing List - %s' % (object.name or '')</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
  </record>

  <!-- Report 2: Packing List (WITH dates) - SHORT TEMPLATE ID -->
  <record id="action_report_packing_list_with_dates" model="ir.actions.report">
    <field name="name">Packing List (With Dates)</field>
    <field name="model">account.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">cycom_packing_list.pl_date_tmpl</field>
    <field name="report_file">cycom_packing_list.pl_date_tmpl</field>
    <field name="print_report_name">'Packing List With Dates - %s' % (object.name or '')</field>
    <field name="binding_model_id" ref="account.model_account_move"/>
    <field name="binding_type">report</field>
  </record>
</cycom>
