<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="res_config_settings_view_form_geofence" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.geofence</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="priority" eval="1000"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[field[@name='attendance_device_tracking']]" position="after">
                <setting string="Restrict Attendance by Company Location"
                    company_dependent="1"
                    help="Allow check-in only when employees are inside the configured company radius.">
                    <field name="attendance_geo_enforce"/>
                    <div class="mt-2" invisible="not attendance_geo_enforce">
                        <div class="o_row mb-2">
                            <span class="me-2">Company Coordinates</span>
                            <field name="attendance_geo_latitude" class="oe_inline"/>
                            <span class="mx-1">,</span>
                            <field name="attendance_geo_longitude" class="oe_inline"/>
                        </div>
                        <div class="o_row">
                            <span class="me-2">Allowed Radius</span>
                            <field name="attendance_geo_radius_m" class="oe_inline" style="width: 8rem;"/>
                            <span class="ms-2">meters</span>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

    <record id="res_company_view_form_geofence" model="ir.ui.view">
        <field name="name">res.company.view.form.geofence</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="priority" eval="1000"/>
        <field name="arch" type="xml">
            <field name="parent_id" position="after">
                <group string="Attendance Geofence" groups="hr_attendance.group_hr_attendance_manager">
                    <field name="attendance_geo_enforce"/>
                    <field name="attendance_geo_latitude" invisible="not attendance_geo_enforce"/>
                    <field name="attendance_geo_longitude" invisible="not attendance_geo_enforce"/>
                    <field name="attendance_geo_radius_m" invisible="not attendance_geo_enforce"/>
                </group>
            </field>
        </field>
    </record>

</cycom>
