<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <data>

        <!-- Employee model search (used by HR and inherited employee search views) -->
        <record id="view_employee_filter_inherit_employee_number" model="ir.ui.view">
            <field name="name">hr.employee.search.employee.number</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='name']" position="after">
                    <field name="employee_number" string="Employee Number" filter_domain="[('employee_number', 'ilike', self)]"/>
                </xpath>
            </field>
        </record>

        <!-- Attendance -->
        <record id="hr_attendance_view_filter_inherit_employee_number" model="ir.ui.view">
            <field name="name">hr.attendance.search.employee.number</field>
            <field name="model">hr.attendance</field>
            <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='employee_id']" position="attributes">
                    <attribute name="filter_domain">['|', ('employee_id.name', 'ilike', self), ('employee_id.employee_number', 'ilike', self)]</attribute>
                </xpath>
            </field>
        </record>

