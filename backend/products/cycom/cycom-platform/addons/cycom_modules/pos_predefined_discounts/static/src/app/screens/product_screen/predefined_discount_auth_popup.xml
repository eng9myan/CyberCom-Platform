<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_predefined_discounts.PredefinedDiscountAuthPopup">
        <Dialog title="props.title" size="'lg'">
            <div class="mb-3">
                <label class="form-label">Discount</label>
                <select class="form-select" t-model.number="state.discountId" t-on-change="onDiscountChange">
                    <t t-foreach="props.discounts" t-as="discount" t-key="discount.id">
                        <option t-att-value="discount.id">
                            <t t-esc="discount.name"/> - <t t-esc="discount.discount"/>%
                        </option>
                    </t>
                </select>
            </div>

            <div class="form-check mb-3" t-if="showEmployeeOptions">
                <input
                    class="form-check-input"
                    type="checkbox"
                    id="pos_predefined_discount_is_employee"
                    t-att-checked="state.isEmployee"
                    t-on-change="onIsEmployeeChange"
                />
                <label class="form-check-label" for="pos_predefined_discount_is_employee">
                    Is Employee
                </label>
            </div>

            <div class="mb-3" t-if="showEmployeeField">
                <label class="form-label">Employee</label>
                <input
                    class="form-control mb-2"
                    type="text"
                    placeholder="Search by name or barcode..."
                    t-model="state.search"
                />
                <select class="form-select" t-model.number="state.employeeId">
                    <t t-foreach="filteredEmployees" t-as="emp" t-key="emp.id">
                        <option t-att-value="emp.id">
                            <t t-esc="emp.name"/>
                            <t t-if="emp.barcode"> (<t t-esc="emp.barcode"/>)</t>
                        </option>
                    </t>
                </select>
            </div>

            <div>
                <label class="form-label">Password</label>
                <input
                    class="form-control"
                    type="password"
                    inputmode="numeric"
                    autocomplete="new-password"
                    autocapitalize="off"
                    autocorrect="off"
                    spellcheck="false"
                    name="pos_discount_auth_password"
                    value=""
                    t-model="state.password"
                    t-ref="password"
                />
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-primary btn-lg lh-lg" t-att-disabled="!canConfirm" t-on-click="confirm">
                    Confirm
                </button>
                <button class="btn btn-secondary btn-lg lh-lg" t-on-click="cancel">
                    Cancel
                </button>
            </t>
        </Dialog>
    </t>
</templates>
