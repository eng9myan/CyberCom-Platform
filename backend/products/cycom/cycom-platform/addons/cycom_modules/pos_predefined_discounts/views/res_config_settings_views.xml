<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="res_config_settings_view_form_inherit_pos_predefined_discounts" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_predefined_discounts</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="pos_discount.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_discount_pc']/ancestor::div[contains(@class, 'row')][1]" position="after">
                <div class="row" invisible="not pos_module_pos_discount">
                    <label string="Allowed Discounts" for="pos_predefined_discount_ids" class="col-lg-3 o_light_label"/>
                    <field name="pos_predefined_discount_ids"
                           colspan="4"
                           readonly="pos_has_active_session"
                           context="{'default_pos_config_id': pos_config_id}">
                    </field>
                </div>
            </xpath>
        </field>
    </record>
</cycom>

