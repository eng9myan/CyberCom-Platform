<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_pos_predefined_discount_tree" model="ir.ui.view">
        <field name="name">pos.predefined.discount.tree</field>
        <field name="model">pos.predefined.discount</field>
        <field name="arch" type="xml">
            <list editable="bottom" create="1" delete="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="discount"/>
                <field name="is_employee_discount"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="pos_config_id"/>
            </list>
        </field>
    </record>

    <record id="view_pos_predefined_discount_form" model="ir.ui.view">
        <field name="name">pos.predefined.discount.form</field>
        <field name="model">pos.predefined.discount</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="sequence"/>
                        <field name="pos_config_id" required="1"/>
                        <field name="name" required="1"/>
                        <field name="discount" required="1"/>
                        <field name="is_employee_discount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</cycom>

