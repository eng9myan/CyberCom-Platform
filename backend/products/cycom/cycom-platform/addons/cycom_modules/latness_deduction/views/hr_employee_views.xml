<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_employee_form_inherit_lateness_annual_leave_balance" model="ir.ui.view">
        <field name="name">hr.employee.form.lateness.annual.leave</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']/group[@name='settings_group']" position="inside">
                <group string="Lateness Coverage" name="lateness_coverage_group" groups="hr.group_hr_user">
                    <field name="annual_leave_balance_hours" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_employee_form_inherit_deduct_extra_hours_visibility" model="ir.ui.view">
        <field name="name">hr.employee.form.deduct.extra.hours.visibility</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_holidays_attendance.hr_employee_view_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="has_non_cancelled_payslip" invisible="1"/>
            </xpath>
            <xpath expr="//header/button[@type='action' and contains(@context, 'deduct_extra_hours')]" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
        </field>
    </record>
</cycom>
