<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_pledge.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension">

        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/NoteButton" position="after">
            
            <!-- SELECT EMPLOYEE BUTTON -->
            <button class="btn btn-primary btn-lg"
                    t-att-class="buttonClass"
                    t-on-click="() => this.onClickSelectEmployee()">
                <i class="fa fa-user me-1"/>
                Select Employee
            </button>

            <!-- RETURN PLEDGE BUTTON -->
            <button class="btn btn-info btn-lg"
                    t-att-class="buttonClass"
                    t-on-click="() => this.onClickReturnPledge()">
                <i class="fa fa-undo me-1"/>
                Return Pledge
            </button>

        </xpath>
    </t>

</templates>
