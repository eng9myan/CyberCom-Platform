<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- =================================================================== -->
    <!-- INTERNAL RECEIPT: Shows ALL items including pledge/employee/delivery -->
    <!-- =================================================================== -->
    <t t-name="pos_pledge.InternalReceipt" owl="1">
        <div class="pos-receipt internal-receipt">
            <div class="pos-receipt-header">
                <h2 class="text-center mb-3">
                    <strong>⚠️ INTERNAL RECEIPT ⚠️</strong>
                </h2>
                <div class="text-center mb-2">
                    <div class="mb-1"><t t-esc="receipt.company.name"/></div>
                    <div t-if="receipt.company.street"><t t-esc="receipt.company.street"/></div>
                    <div t-if="receipt.company.phone">Tel: <t t-esc="receipt.company.phone"/></div>
                </div>
                <div class="cashier mb-2">
                    <div>Cashier: <t t-esc="receipt.cashier"/></div>
                    <div>Order: <t t-esc="receipt.name"/></div>
                    <div>Date: <t t-esc="receipt.date"/></div>
                </div>
                <t t-if="receipt.partner">
                    <div class="partner-info mb-2">
                        <div><strong>Customer: <t t-esc="receipt.partner.name"/></strong></div>
                        <div t-if="receipt.partner.phone">Phone: <t t-esc="receipt.partner.phone"/></div>
                    </div>
                </t>
            </div>

            <div class="pos-receipt-body">
                <div class="orderlines">
                    <t t-foreach="receipt.orderlines" t-as="line" t-key="line_index">
                        <div class="orderline" t-att-class="{'pledge-item': line.is_pledge_related, 'virtual-pledge': line.is_virtual_pledge}">
                            <div class="d-flex justify-content-between">
                                <div class="flex-grow-1">
                                    <div class="product-name">
                                        <t t-esc="line.product_name"/>
                                        <!-- Badge for special items -->
                                        <t t-if="line.is_virtual_pledge">
                                            <span class="badge bg-success text-white ms-1">VIRTUAL PLEDGE</span>
                                        </t>
                                        <t t-if="line.has_pledge">
                                            <span class="badge bg-warning text-dark ms-1">PLEDGE</span>
                                        </t>
                                        <t t-if="line.is_employee_service">
                                            <span class="badge bg-info text-dark ms-1">EMPLOYEE</span>
                                        </t>
                                        <t t-if="line.is_delivery_service">
                                            <span class="badge bg-primary text-dark ms-1">DELIVERY</span>
                                        </t>
                                    </div>
                                    <div class="product-detail text-muted">
                                        <t t-esc="line.quantity"/> x <t t-esc="line.price_display || line.price"/>
                                    </div>
                                </div>
                                <div class="price text-end">
                                    <t t-esc="line.price_with_tax_display || line.price_display"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="pos-receipt-amount mt-3">
                    <table class="table-borderless w-100">
                        <tr>
                            <td class="text-end"><strong>TOTAL:</strong></td>
                            <td class="text-end price"><strong><t t-esc="receipt.total_with_tax"/></strong></td>
                        </tr>
                        <t t-if="receipt.change">
                            <tr>
                                <td class="text-end">Change:</td>
                                <td class="text-end price"><t t-esc="receipt.change"/></td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>

            <div class="pos-receipt-footer text-center mt-4">
                <div class="alert alert-warning">
                    <strong>FOR INTERNAL USE ONLY</strong><br/>
                    This receipt contains pledge/service details
                </div>
            </div>
        </div>
    </t>

    <!-- =================================================================== -->
    <!-- CUSTOMER RECEIPT: Shows ONLY regular products (NO pledge/employee/delivery) -->
    <!-- =================================================================== -->
    <t t-name="pos_pledge.CustomerReceipt" owl="1">
        <div class="pos-receipt customer-receipt">
            <div class="pos-receipt-header">
                <h2 class="text-center mb-3">RECEIPT</h2>
                <div class="text-center mb-2">
                    <div class="mb-1"><t t-esc="receipt.company.name"/></div>
                    <div t-if="receipt.company.street"><t t-esc="receipt.company.street"/></div>
                    <div t-if="receipt.company.phone">Tel: <t t-esc="receipt.company.phone"/></div>
                </div>
                <div class="cashier mb-2">
                    <div>Cashier: <t t-esc="receipt.cashier"/></div>
                    <div>Order: <t t-esc="receipt.name"/></div>
                    <div>Date: <t t-esc="receipt.date"/></div>
                </div>
                <t t-if="receipt.partner">
                    <div class="partner-info mb-2">
                        <div><strong>Customer: <t t-esc="receipt.partner.name"/></strong></div>
                        <div t-if="receipt.partner.phone">Phone: <t t-esc="receipt.partner.phone"/></div>
                    </div>
                </t>
            </div>

            <div class="pos-receipt-body">
                <div class="orderlines">
                    <t t-foreach="receipt.customerOrderlines" t-as="line" t-key="line_index">
                        <div class="orderline">
                            <div class="d-flex justify-content-between">
                                <div class="flex-grow-1">
                                    <div class="product-name">
                                        <t t-esc="line.product_name"/>
                                    </div>
                                    <div class="product-detail text-muted">
                                        <t t-esc="line.quantity"/> x <t t-esc="line.price"/>
                                    </div>
                                </div>
                                <div class="price text-end">
                                    <t t-esc="line.price_display"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="pos-receipt-amount mt-3">
                    <table class="table-borderless w-100">
                        <tr>
                            <td class="text-end"><strong>TOTAL:</strong></td>
                            <td class="text-end price"><strong><t t-esc="receipt.customer_total"/></strong></td>
                        </tr>
                        <t t-if="receipt.change">
                            <tr>
                                <td class="text-end">Change:</td>
                                <td class="text-end price"><t t-esc="receipt.change"/></td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>

            <div class="pos-receipt-footer text-center mt-4">
                <div>Thank you for your business!</div>
            </div>
        </div>
    </t>

    <!-- =================================================================== -->
    <!-- INHERIT OrderReceipt to add Pledge Amount section -->
    <!-- =================================================================== -->
    <t t-name="pos_pledge.OrderReceipt" 
       t-inherit="point_of_sale.OrderReceipt" 
       t-inherit-mode="extension"
       owl="1">

        <!-- Show active pricelist on the original Cycom receipt -->
        <xpath expr="//ReceiptHeader" position="after">
            <t t-set="orderPricelist"
               t-value="(props.order and props.order.get_pricelist and props.order.get_pricelist()) or (props.order and props.order.pricelist) or (props.order and props.order.pricelist_id)"/>
            <t t-set="orderPricelistName"
               t-value="(orderPricelist and orderPricelist.name) or (Array.isArray(orderPricelist) and orderPricelist[1]) or ''"/>
            <div t-if="orderPricelistName" class="pos-receipt-order-data text-start pt-1">
                Pricelist: <t t-esc="orderPricelistName"/>
            </div>
            <div t-if="props.order and props.order.customer_id_number" class="pos-receipt-order-data text-start pt-1">
                ID Number: <t t-esc="props.order.customer_id_number"/>
            </div>
        </xpath>
        
        <!-- Add Pledge Amount section at the end (match any root element) -->
        <xpath expr="/*" position="inside">
            <!-- Calculate Pledge Amount from Order Lines -->
            <t t-if="props and props.order and props.order.lines">
                <!-- First, check if ANY product is an employee service or delivery product -->
                <t t-set="hasEmployeeService" t-value="false"/>
                <t t-set="hasDeliveryProduct" t-value="false"/>
                <t t-if="props.order.employee_id">
                    <t t-set="hasEmployeeService" t-value="true"/>
                </t>
                <t t-foreach="props.order.lines" t-as="checkLine" t-key="'check_' + checkLine_index">
                    <t t-if="checkLine.product_id and checkLine.product_id.is_employee_service">
                        <t t-set="hasEmployeeService" t-value="true"/>
                    </t>
                    <t t-if="checkLine.product_id and checkLine.product_id.is_delivery_product">
                        <t t-set="hasDeliveryProduct" t-value="true"/>
                    </t>
                </t>
                
                <!-- Only process pledge if NO employee service or delivery product exists -->
                <t t-if="!hasEmployeeService and !hasDeliveryProduct">
                    <t t-set="pledgeLines" t-value="[]"/>
                    <t t-set="totalPledge" t-value="0"/>
                    
                    <!-- Loop through order lines to find pledge products -->
                    <t t-foreach="props.order.lines" t-as="line" t-key="line_index">
                        <t t-set="product" t-value="line.product_id"/>
                        <t t-if="product and product.has_pledge">
                            <t t-set="qty" t-value="line.qty or line.get_quantity and line.get_quantity() or 1"/>
                            <t t-set="pledgeAmt" t-value="(product.pledge_amount or 0) * qty"/>
                            <t t-set="totalPledge" t-value="totalPledge + pledgeAmt"/>
                            <t t-set="void" t-value="pledgeLines.push({'name': product.display_name or product.name, 'amount': pledgeAmt, 'qty': qty})"/>
                        </t>
                    </t>
                    
                    <!-- Display Pledge Section if there are pledge products -->
                    <t t-if="totalPledge > 0">
                    <div class="pos-receipt-pledge-section" style="border-top: 2px dashed #000; margin-top: 20px; padding-top: 15px; page-break-inside: avoid;">
                        <h4 class="text-center" style="font-weight: bold; margin-bottom: 10px; text-decoration: underline;">
                            معلومات الرهن / Pledge Information
                        </h4>
                        
                        <table class="table-borderless w-100" style="margin-bottom: 10px;">
                            <!-- List each pledge product -->
                            <t t-foreach="pledgeLines" t-as="pline" t-key="pline_index">
                                <tr>
                                    <td style="padding: 3px 0;">
                                        <t t-esc="pline.name"/>
                                        <t t-if="pline.qty > 1">
                                            <span style="color: #666; font-size: 0.9em;"> (x<t t-esc="pline.qty"/>)</span>
                                        </t>
                                    </td>
                                    <td class="text-end" style="padding: 3px 0;">
                                        $ <t t-esc="pline.amount.toFixed(2)"/>
                                    </td>
                                </tr>
                            </t>
                            
                            <!-- Total pledge amount -->
                            <tr style="border-top: 2px solid #000; margin-top: 10px;">
                                <td style="padding-top: 8px;">
                                    <strong>إجمالي الرهن / Total Pledge:</strong>
                                </td>
                                <td class="text-end" style="padding-top: 8px;">
                                    <strong style="font-size: 1.1em;">
                                        $ <t t-esc="totalPledge.toFixed(2)"/>
                                    </strong>
                                </td>
                            </tr>
                        </table>
                        
                        <div class="text-center" style="font-size: 0.85em; color: #666; font-style: italic; margin-top: 8px; border-top: 1px dashed #999; padding-top: 8px;">
                            ⚠️ هذا المبلغ سيُرد عند إعادة المنتج<br/>
                            This amount will be refunded upon product return
                        </div>
                    </div>
                </t>
                </t>
            </t>
        </xpath>
    </t>

</templates>
