<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_pledge.PledgePopup">
        <Dialog title="'Pledge Configuration'" t-on-click="props.close">
            <div class="pledge-popup-content">
                <!-- Case Information -->
                <div class="pledge-case-info mb-3">
                    <h4><t t-esc="getCaseTitle()"/></h4>
                    <p class="text-muted"><t t-esc="getCaseDescription()"/></p>
                </div>

                <!-- Amounts Display -->
                <div class="pledge-amounts">
                    
                    <!-- Pledge Amount -->
                    <div class="form-group mb-3" t-if="state.pledgeAmount > 0">
                        <label class="form-label fw-bold">Pledge Amount</label>
                        <div class="input-group">
                            <input type="number" 
                                   class="form-control form-control-lg"
                                   t-att-value="state.pledgeAmount"
                                   t-on-change="onPledgeAmountChange"
                                   step="0.01"
                                   min="0"/>
                            <span class="input-group-text">
                                <t t-esc="pos.currency.symbol"/>
                            </span>
                        </div>
                        <small class="text-muted">Liability account entry will be created</small>
                    </div>

                    <!-- Employee Amount -->
                    <div class="form-group mb-3" t-if="state.employeeAmount > 0">
                        <label class="form-label fw-bold">Employee Service Amount</label>
                        <div class="input-group">
                            <input type="number" 
                                   class="form-control form-control-lg"
                                   t-att-value="state.employeeAmount"
                                   t-on-change="onEmployeeAmountChange"
                                   step="0.01"
                                   min="0"/>
                            <span class="input-group-text">
                                <t t-esc="pos.currency.symbol"/>
                            </span>
                        </div>
                        <small class="text-muted">Service account entry will be created</small>
                    </div>

                    <!-- Delivery Amount -->
                    <div class="form-group mb-3" t-if="state.deliveryAmount > 0">
                        <label class="form-label fw-bold">Delivery Service Amount</label>
                        <div class="input-group">
                            <input type="number" 
                                   class="form-control form-control-lg"
                                   t-att-value="state.deliveryAmount"
                                   t-on-change="onDeliveryAmountChange"
                                   step="0.01"
                                   min="0"/>
                            <span class="input-group-text">
                                <t t-esc="pos.currency.symbol"/>
                            </span>
                        </div>
                        <small class="text-muted">Service account entry will be created</small>
                    </div>

                    <!-- Summary -->
                    <div class="pledge-summary mt-4 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Customer Invoice Total:</strong>
                            <span class="fs-5">
                                <t t-esc="pos.env.utils.formatCurrency(state.customerTotal)"/>
                            </span>
                        </div>
                        <div class="d-flex justify-content-between mb-2" t-if="state.pledgeAmount > 0">
                            <span>+ Pledge:</span>
                            <span><t t-esc="pos.env.utils.formatCurrency(state.pledgeAmount)"/></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2" t-if="state.employeeAmount > 0">
                            <span>+ Employee Service:</span>
                            <span><t t-esc="pos.env.utils.formatCurrency(state.employeeAmount)"/></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2" t-if="state.deliveryAmount > 0">
                            <span>+ Delivery Service:</span>
                            <span><t t-esc="pos.env.utils.formatCurrency(state.deliveryAmount)"/></span>
                        </div>
                        <hr/>
                        <div class="d-flex justify-content-between">
                            <strong>Total to Collect:</strong>
                            <strong class="fs-4 text-primary">
                                <t t-esc="pos.env.utils.formatCurrency(state.totalAmount)"/>
                            </strong>
                        </div>
                    </div>

                    <!-- Warning -->
                    <div class="alert alert-info mt-3">
                        <i class="fa fa-info-circle"/> 
                        Two receipts will be generated: Internal (with all items) and Customer (products only)
                    </div>
                </div>

                <!-- Footer Buttons -->
                <div class="modal-footer mt-3">
                    <button class="btn btn-secondary" t-on-click="onCancel">
                        Cancel
                    </button>
                    <button class="btn btn-primary" t-on-click="onConfirm">
                        Confirm
                    </button>
                </div>
            </div>
        </Dialog>
    </t>

</templates>
