<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_hr_payslip_form_inherit_extra_hours_adjustment" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.extra.hours.adjustment</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='account_info']/group/group[1]/field[@name='employee_extra_hours_balance']" position="after">
                <field
                    name="manual_extra_hours_balance"
                    widget="float_time"
                    groups="payroll_extra_hours_adjustment.group_extra_hours_adjustment_manager"
                />
                <button
                    name="action_apply_additional_extra_hours"
                    type="object"
                    string="Apply Additional Extra Hours"
                    class="btn-primary"
                    groups="payroll_extra_hours_adjustment.group_extra_hours_adjustment_manager"
                />
                <button
                    name="action_reset_additional_extra_hours"
                    type="object"
                    string="Cancel / Reset Additional Extra Hours"
                    class="btn-secondary"
                    groups="payroll_extra_hours_adjustment.group_extra_hours_adjustment_manager"
                    invisible="not additional_extra_hours_line_id or additional_extra_hours_reversal_line_id"
                />
            </xpath>
        </field>
    </record>
</cycom>
