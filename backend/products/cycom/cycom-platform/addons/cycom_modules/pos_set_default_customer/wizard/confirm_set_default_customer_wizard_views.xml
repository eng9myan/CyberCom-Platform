<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_confirm_set_default_customer_wizard_form" model="ir.ui.view">
        <field name="name">pos.set.default.customer.wizard.form</field>
        <field name="model">pos.set.default.customer.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Customer Update">
                <group>
                    <field name="partner_id"/>
                    <field name="records_count"/>
                </group>
                <footer>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Proceed"
                        class="btn-primary"
                    />
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</cycom>
