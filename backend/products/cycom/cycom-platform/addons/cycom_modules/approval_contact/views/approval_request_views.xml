<cycom>
    <record id="view_approval_request_form_inherit_contact_creation" model="ir.ui.view">
        <field name="name">approval.request.form.inherit.contact.creation</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">

            <!-- Add Contact Fields -->
            <xpath expr="//sheet" position="inside">
                <group string="New Contact Data"
                       invisible="not x_is_contact_creation_category">

                    <field name="x_contact_type" required="x_is_contact_creation_category"/>
                    <field name="x_contact_name" required="x_is_contact_creation_category"/>
                    <field name="x_contact_phone" required="x_is_contact_creation_category"/>
                    <field name="x_contact_email"/>
                    <field name="x_contact_vat" required="x_is_contact_creation_category"/>

                    <field name="x_created_partner_id" readonly="1"/>
                </group>
            </xpath>

            <!-- Smart Button to open created contact -->
            <xpath expr="//header" position="inside">
                <button name="action_open_created_contact"
                        type="object"
                        string="Created Contact"
                        class="oe_stat_button"
                        invisible="not x_created_partner_id"/>
            </xpath>

        </field>
    </record>
</cycom>
