<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="pos_receipt_design2_demo" model="pos.receipt">
        <field name="name">Design 2</field>
        <field name="design_receipt"><![CDATA[
<div class="pos-receipt p-2">
    <div class="text-center border-bottom pb-2">
        <t t-if="order.config.logo">
            <img t-att-src="'data:image/png;base64,' + order.config.logo" class="pos-receipt-logo" alt="Logo"/>
        </t>
        <h3 class="m-0" t-esc="order.company.name"/>
        <div t-if="order.company.street" t-esc="order.company.street"/>
        <div t-if="order.company.phone">Phone: <span t-esc="order.company.phone"/></div>
        <div t-if="order.company.email" t-esc="order.company.email"/>
        <div t-if="order.company.vat" t-esc="vatText"/>
    </div>

    <div class="pt-2">
        <div><strong>Receipt:</strong> <span t-esc="order.name"/></div>
        <div><strong>Date:</strong> <span t-esc="order.formatDateOrTime('date_order')"/></div>
        <div t-if="header.cashier"><strong>Cashier:</strong> <span t-esc="header.cashier"/></div>
        <div t-if="order.partner_id"><strong>Customer:</strong> <span t-esc="order.partner_id.name"/></div>
    </div>

    <table class="receipt-orderlines w-100 mt-3 border-top border-bottom">
        <thead>
            <tr>
                <th class="text-start">Item</th>
                <th class="text-end">Qty</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody>
            <tr t-foreach="order.lines" t-as="line" t-key="line.uuid">
                <td>
                    <span t-esc="line.product_id.display_name"/>
                    <div t-if="line.discount" class="small">
                        Discount: <span t-esc="line.discount"/>%
                    </div>
                </td>
                <td class="text-end" t-esc="line.qty"/>
                <td class="text-end" t-esc="formatCurrency(line.price_display)"/>
            </tr>
        </tbody>
    </table>

    <div class="pt-3">
        <div class="d-flex">
            <span>Subtotal</span>
            <span class="ms-auto" t-esc="formatCurrency(order.priceExcl)"/>
        </div>

        <div t-if="order.prices.taxDetails and order.prices.taxDetails.has_tax_groups">
            <t t-foreach="order.prices.taxDetails.subtotals" t-as="subtotal" t-key="subtotal.name">
                <t t-foreach="subtotal.tax_groups" t-as="tax_group" t-key="tax_group.id">
                    <div class="d-flex">
                        <span t-esc="tax_group.group_name"/>
                        <span class="ms-auto" t-esc="formatCurrency(tax_group.tax_amount_currency)"/>
                    </div>
                </t>
            </t>
        </div>

        <div class="d-flex fw-bolder border-top pt-1">
            <span>TOTAL</span>
            <span class="ms-auto" t-esc="order.currencyDisplayPriceIncl"/>
        </div>
    </div>

    <div class="pt-2 border-top mt-2" t-foreach="paymentLines" t-as="line" t-key="line.uuid">
        <div class="d-flex">
            <span t-esc="line.payment_method_id.name"/>
            <span class="ms-auto" t-esc="formatCurrency(line.getAmount())"/>
        </div>
    </div>

    <div t-if="order.showChange" class="d-flex fw-bolder">
        <span>CHANGE</span>
        <span class="ms-auto" t-esc="formatCurrency(order.change)"/>
    </div>

    <div t-if="order.config.receipt_footer" class="text-center pt-3" style="white-space:pre-line">
        <t t-esc="order.config.receipt_footer"/>
    </div>

    <div class="text-center pt-3">
        Powered by Cycom
    </div>
</div>
        ]]></field>
    </record>
</cycom>
