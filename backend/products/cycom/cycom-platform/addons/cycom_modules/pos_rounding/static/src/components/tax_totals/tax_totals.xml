<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <xpath expr="//tr[last()]" position="before">
            <tr t-if="totals.pos_open_amount_currency">
                <td class="o_td_label">
                    <label class="o_form_label o_tax_total_label" t-out="totals.pos_open_amount_label || 'Open Amount'"/>
                </td>
                <td class="o_list_monetary">
                    <span t-out="formatMonetary(totals.pos_open_amount_currency)"/>
                </td>
            </tr>
        </xpath>
    </t>
</templates>
