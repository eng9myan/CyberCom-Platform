<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <template id="document_tax_totals_open_amount" inherit_id="account.document_tax_totals">
        <xpath expr="//tr[@class='o_total']" position="before">
            <tr t-if="tax_totals.get('pos_open_amount_currency')">
                <td>
                    <span t-out="tax_totals.get('pos_open_amount_label') or 'Open Amount'"/>
                </td>
                <td class="text-end o_price_total">
                    <span class="text-nowrap"
                          t-out="tax_totals['pos_open_amount_currency']"
                          t-options='{"widget": "monetary", "display_currency": currency}'/>
                </td>
            </tr>
        </xpath>
    </template>

    <template id="document_tax_totals_company_currency_open_amount" inherit_id="account.document_tax_totals_company_currency_template">
        <xpath expr="//tr[@class='o_total']" position="before">
            <tr t-if="tax_totals.get('pos_open_amount')">
                <td>
                    <span t-out="tax_totals.get('pos_open_amount_label') or 'Open Amount'"/>
                </td>
                <td class="text-end o_price_total">
                    <span class="text-nowrap"
                          t-out="tax_totals['pos_open_amount']"
                          t-options='{"widget": "monetary", "display_currency": currency}'/>
                </td>
            </tr>
        </xpath>
    </template>
</cycom>
