<?xml version="1.0" encoding="UTF-8" ?>
<cycom>
    <record id="updated_view_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.remove.domain</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_type_id']" position="replace"/>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="picking_type_id" readonly="state in ('done', 'cancel')" options="{'no_open': True}"/>
            </xpath>
        </field>
    </record>
</cycom>