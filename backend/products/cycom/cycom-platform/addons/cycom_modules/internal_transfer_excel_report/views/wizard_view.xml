<cycom>

    <!-- Wizard View -->
    <record id="view_internal_transfer_wizard" model="ir.ui.view">
        <field name="name">internal.transfer.wizard.form</field>
        <field name="model">internal.transfer.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Internal Transfer Report">
                <group>
                    <field name="filter_type"/>

                    <field name="date_from" invisible="filter_type != 'custom'"
                    />

                    <field name="date_to" invisible="filter_type != 'custom'"/>

                    <field name="category_id"/>
                </group>

                <footer>
                    <button name="action_print_excel"
                            type="object"
                            string="Print Excel"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_internal_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Internal Transfer Report</field>
        <field name="res_model">internal.transfer.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_internal_transfer_report"
              name="Internal Transfer Report"
              parent="stock.menu_stock_warehouse_mgmt"
              action="action_internal_transfer_wizard"/>



</cycom>