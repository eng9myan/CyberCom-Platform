<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="paperformat_employee_profile" model="report.paperformat">
        <field name="name">Employee Profile A4</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">12</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_employee_profile" model="ir.actions.report">
        <field name="name">Employee Profile</field>
        <field name="model">hr.employee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cycom_employee_profile.emp_profile_pdf</field>
        <field name="report_file">cycom_employee_profile.emp_profile_pdf</field>
        <field name="paperformat_id" ref="paperformat_employee_profile"/>
        <field name="print_report_name">'Employee Profile - %s' % (object.name or '')</field>
    </record>
</cycom>
