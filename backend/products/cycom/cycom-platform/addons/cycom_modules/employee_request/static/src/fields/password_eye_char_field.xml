<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="employee_request.PasswordEyeCharField">
        <t t-if="props.readonly">
            <span t-esc="state.show ? value : maskedValue"/>
            <button type="button"
                class="btn btn-link btn-sm px-1 py-0"
                t-on-click="toggleShow"
                title="Show/Hide">
                <i class="fa" t-att-class="state.show ? 'fa-eye-slash' : 'fa-eye'"/>
            </button>
        </t>
        <t t-else="">
            <div class="input-group">
                <input
                    class="o_input form-control"
                    t-att-id="props.id"
                    t-att-type="state.show ? 'text' : (props.isPassword ? 'password' : 'text')"
                    t-att-placeholder="props.placeholder"
                    t-att-autocomplete="props.autocomplete or (props.isPassword ? 'new-password' : 'off')"
                    t-ref="input"
                />
                <button type="button"
                    class="btn border border-start-0 o_show_password"
                    t-on-click="toggleShow"
                    title="Show/Hide">
                    <i class="fa" t-att-class="state.show ? 'fa-eye-slash' : 'fa-eye'"/>
                </button>
            </div>
        </t>
    </t>
</templates>

