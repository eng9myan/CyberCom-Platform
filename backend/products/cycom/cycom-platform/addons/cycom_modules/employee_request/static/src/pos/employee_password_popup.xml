<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="employee_request.EmployeePasswordPopup">
        <Dialog title="props.title" size="'lg'">
            <div class="mb-2">
                <label class="form-label">Employee</label>
                <input class="form-control mb-2" type="text" placeholder="Search by name or barcode..."
                    t-model="state.search"/>
                <select class="form-select" t-model.number="state.employeeId">
                    <t t-foreach="filteredEmployees" t-as="emp" t-key="emp.id">
                        <option t-att-value="emp.id">
                            <t t-esc="emp.name"/>
                            <t t-if="emp.barcode"> (<t t-esc="emp.barcode"/>)</t>
                        </option>
                    </t>
                </select>
            </div>

            <div>
                <label class="form-label">Password</label>
                <input class="form-control" type="password" inputmode="numeric" autocomplete="off"
                    t-model="state.password" t-ref="password"/>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-primary btn-lg lh-lg" t-att-disabled="!canConfirm" t-on-click="confirm">
                    Confirm
                </button>
                <button class="btn btn-secondary btn-lg lh-lg" t-on-click="cancel">
                    Cancel
                </button>
            </t>
        </Dialog>
    </t>
</templates>

