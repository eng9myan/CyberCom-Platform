<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_mep_id.MepIdPopup">
        <Dialog title="props.title">
            <input
                t-ref="mep_id_input"
                t-model="state.mepId"
                type="text"
                class="form-control form-control-lg mx-auto"
                t-att-placeholder="props.placeholder"
            />
            <t t-set-slot="footer">
                <button
                    class="btn btn-primary btn-lg lh-lg"
                    t-att-disabled="!canConfirm"
                    t-on-click="confirm"
                >
                    <t t-esc="props.confirmLabel"/>
                </button>
                <button class="btn btn-secondary btn-lg lh-lg" t-on-click="cancel">
                    <t t-esc="props.cancelLabel"/>
                </button>
            </t>
        </Dialog>
    </t>
</templates>
