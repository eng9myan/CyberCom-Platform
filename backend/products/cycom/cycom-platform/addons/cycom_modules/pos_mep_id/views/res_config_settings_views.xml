<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="res_config_settings_view_form_inherit_pos_mep_id" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.mep.id</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_payment_method_ids']/ancestor::setting[1]" position="after">
                <setting
                    id="pos_mep_payment_methods_setting"
                    string="Visa Payment Methods"
                    help="Payment methods that require entering a Visa ID in POS."
                >
                    <field
                        name="pos_mep_payment_method_ids"
                        widget="many2many_tags"
                        options="{'no_create': True}"
                        domain="[('id', 'in', pos_payment_method_ids)]"
                    />
                </setting>
            </xpath>
        </field>
    </record>
</cycom>
