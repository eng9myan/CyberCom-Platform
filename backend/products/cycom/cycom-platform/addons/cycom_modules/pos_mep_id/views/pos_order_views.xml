<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_pos_order_form_inherit_pos_mep_id" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.pos.mep.id</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="mep_id" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_pos_order_tree_inherit_pos_mep_id" model="ir.ui.view">
        <field name="name">pos.order.tree.inherit.pos.mep.id</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="mep_id" readonly="1" optional="hide"/>
            </field>
        </field>
    </record>
</cycom>
