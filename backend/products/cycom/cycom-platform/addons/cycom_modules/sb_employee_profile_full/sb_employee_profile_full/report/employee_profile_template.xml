<cycom>
  <template id="employee_profile_pdf">
    <t t-call="web.external_layout">
      <t t-foreach="docs" t-as="emp">
        <t t-set="p" t-value="emp.sb_profile_payload()"/>

        <style>
          .sb-title { font-size: 18px; font-weight: 600; color: #d55b3f; }
          .sb-box { border: 1px solid #777; padding: 6px; }
          .sb-grid { width: 100%; border-collapse: collapse; font-size: 11px; }
          .sb-grid td, .sb-grid th { border: 1px solid #777; padding: 3px; vertical-align: top; }
          .sb-noborder td, .sb-noborder th { border: 0 !important; }
          .sb-headrow { background: #f4f4f4; font-weight: 600; }
          .sb-section { font-weight: 700; padding: 4px 0; }
          .sb-tight td, .sb-tight th { padding: 2px; }
          .sb-small { font-size: 10px; }
          .sb-photo { border: 1px solid #777; width: 70px; height: 70px; object-fit: cover; }
        </style>

        <div class="page sb-box">
          <!-- Header -->
          <table class="sb-grid sb-noborder" style="width:100%;">
            <tr>
              <td style="width:50%;">
                <div class="sb-title">Employee Profile</div>
              </td>
              <td style="width:35%; text-align:center;">
                <t t-if="emp.company_id and emp.company_id.logo">
                  <img t-att-src="image_data_uri(emp.company_id.logo)" style="height:35px;"/>
                </t>
                <div class="sb-small" style="font-weight:700;">
                  <t t-esc="emp.company_id.name if emp.company_id else ''"/>
                </div>
              </td>
              <td style="width:15%; text-align:right;">
                <t t-if="emp.image_128">
                  <img class="sb-photo" t-att-src="image_data_uri(emp.image_128)"/>
                </t>
              </td>
            </tr>
          </table>

          <!-- Employee info (3 columns) -->
          <table class="sb-grid sb-tight" style="margin-top:6px;">
            <tr>
              <td style="width:34%;">
                <table class="sb-grid sb-tight">
                  <tr><th style="width:40%;">Number</th><td t-esc="p['number']"/></tr>
                  <tr><th>Name</th><td t-esc="p['name']"/></tr>
                  <tr><th>Alternate Name</th><td t-esc="p['alt_name']"/></tr>
                  <tr><th>Start Date</th><td t-esc="p['start_date']"/></tr>
                  <tr><th>Job</th><td t-esc="p['job']"/></tr>
                  <tr><th>Type</th><td t-esc="p['type']"/></tr>
                </table>
              </td>

              <td style="width:33%;">
                <table class="sb-grid sb-tight">
                  <tr><th style="width:45%;">Gender</th><td t-esc="p['gender']"/></tr>
                  <tr><th>Marital Status</th><td t-esc="p['marital']"/></tr>
                  <tr><th>Nationality</th><td t-esc="p['nationality']"/></tr>
                  <tr><th>National Number</th><td t-esc="p['national_number']"/></tr>
                  <tr><th>SS Number</th><td t-esc="p['ss_number']"/></tr>
                  <tr><th>Mother Name</th><td t-esc="p['mother_name']"/></tr>
                  <tr><th>Bank</th><td t-esc="p['bank']"/></tr>
                  <tr><th>Bank Branch</th><td t-esc="p['bank_branch']"/></tr>
                  <tr><th>Income Tax Number</th><td t-esc="p['income_tax_number']"/></tr>
                </table>
              </td>

              <td style="width:33%;">
                <table class="sb-grid sb-tight">
                  <tr><th style="width:40%;">Birth Date</th><td t-esc="p['birth_date']"/></tr>
                  <tr><th>Birth Place</th><td t-esc="p['birth_place']"/></tr>
                  <tr><th>Home Phone</th><td t-esc="p['home_phone']"/></tr>
                  <tr><th>Mobile No.</th><td t-esc="p['mobile']"/></tr>
                  <tr><th>Status</th><td t-esc="p['status']"/></tr>
                  <tr><th>Termination Date</th><td t-esc="p['termination_date']"/></tr>
                  <tr><th>City</th><td t-esc="p['city']"/></tr>
                  <tr><th>Address</th><td t-esc="p['address']"/></tr>
                  <tr><th>Email</th><td t-esc="p['email']"/></tr>
                  <tr><th>Blood Type</th><td t-esc="p['blood_type']"/></tr>
                </table>
              </td>
            </tr>
          </table>

          <!-- Salary line -->
          <table class="sb-grid sb-tight" style="margin-top:6px;">
            <tr>
              <th style="width:20%;">Basic Salary</th>
              <td style="width:20%;" t-esc="p['basic_salary']"/>
              <th style="width:15%;">SS Salary</th>
              <td style="width:15%;" t-esc="p['ss_salary']"/>
              <th style="width:25%;">Service Charge / Points</th>
              <td style="width:20%;">
                <span t-esc="p['service_charge']"/> / <span t-esc="p['points']"/>
              </td>
            </tr>
          </table>

          <!-- Dependants & Warnings -->
          <table class="sb-grid" style="margin-top:8px;">
            <tr>
              <td style="width:50%;">
                <div class="sb-section">Dependants</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th style="width:6%;">No.</th>
                    <th>Name</th>
                    <th style="width:18%;">Birth Date</th>
                    <th style="width:18%;">Birth Place</th>
                    <th style="width:18%;">Medical Ins.</th>
                    <th style="width:10%;">Cover</th>
                  </tr>
                  <t t-set="i" t-value="1"/>
                  <t t-foreach="p['dependants']" t-as="d">
                    <tr>
                      <td t-esc="i"/><t t-set="i" t-value="i+1"/>
                      <td t-esc="d['name']"/>
                      <td t-esc="d['birth_date']"/>
                      <td t-esc="d['birth_place']"/>
                      <td t-esc="d['medical_ins']"/>
                      <td style="text-align:center;">
                        <t t-if="d['cover']">☑</t><t t-else="">☐</t>
                      </td>
                    </tr>
                  </t>
                  <t t-if="not p['dependants']">
                    <tr><td colspan="6" style="height:40px;"></td></tr>
                  </t>
                </table>
              </td>

              <td style="width:50%;">
                <div class="sb-section">Warnings</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th style="width:22%;">Date</th>
                    <th style="width:22%;">Warning Type</th>
                    <th>Reason</th>
                  </tr>
                  <t t-foreach="p['warnings']" t-as="w">
                    <tr>
                      <td t-esc="w['date']"/>
                      <td t-esc="w['type']"/>
                      <td t-esc="w['reason']"/>
                    </tr>
                  </t>
                  <t t-if="not p['warnings']">
                    <tr><td colspan="3" style="height:40px;"></td></tr>
                  </t>
                </table>
              </td>
            </tr>
          </table>

          <!-- Previous Jobs & Education -->
          <table class="sb-grid" style="margin-top:8px;">
            <tr>
              <td style="width:50%;">
                <div class="sb-section">Previous Jobs</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th>Employer</th>
                    <th style="width:18%;">Start</th>
                    <th style="width:18%;">End</th>
                    <th>Occupation</th>
                    <th>Termination Reason</th>
                  </tr>
                  <t t-foreach="p['previous_jobs']" t-as="j">
                    <tr>
                      <td t-esc="j['employer']"/>
                      <td t-esc="j['start_date']"/>
                      <td t-esc="j['end_date']"/>
                      <td t-esc="j['occupation']"/>
                      <td t-esc="j['termination_reason']"/>
                    </tr>
                  </t>
                  <t t-if="not p['previous_jobs']">
                    <tr><td colspan="5" style="height:35px;"></td></tr>
                  </t>
                </table>
              </td>

              <td style="width:50%;">
                <div class="sb-section">Education</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th style="width:12%;">Year</th>
                    <th style="width:25%;">Degree</th>
                    <th>Specialty</th>
                    <th>Institute</th>
                  </tr>
                  <t t-foreach="p['education']" t-as="e">
                    <tr>
                      <td t-esc="e['year']"/>
                      <td t-esc="e['degree']"/>
                      <td t-esc="e['specialty']"/>
                      <td t-esc="e['institute']"/>
                    </tr>
                  </t>
                  <t t-if="not p['education']">
                    <tr><td colspan="4" style="height:35px;"></td></tr>
                  </t>
                </table>
              </td>
            </tr>
          </table>

          <!-- Official Documents & Career Movements -->
          <table class="sb-grid" style="margin-top:8px;">
            <tr>
              <td style="width:50%;">
                <div class="sb-section">Official Documents</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th style="width:22%;">Type</th>
                    <th style="width:20%;">Number</th>
                    <th>Issue Place</th>
                    <th style="width:18%;">Issue Date</th>
                    <th style="width:18%;">Expiry Date</th>
                  </tr>
                  <t t-foreach="p['official_docs']" t-as="d">
                    <tr>
                      <td t-esc="d['type']"/>
                      <td t-esc="d['number']"/>
                      <td t-esc="d['issue_place']"/>
                      <td t-esc="d['issue_date']"/>
                      <td t-esc="d['expiry_date']"/>
                    </tr>
                  </t>
                  <t t-if="not p['official_docs']">
                    <tr><td colspan="5" style="height:35px;"></td></tr>
                  </t>
                </table>
              </td>

              <td style="width:50%;">
                <div class="sb-section">Career Movements</div>
                <table class="sb-grid sb-tight">
                  <tr class="sb-headrow">
                    <th style="width:22%;">Type</th>
                    <th style="width:20%;">Date</th>
                    <th>Old</th>
                    <th>New</th>
                  </tr>
                  <t t-foreach="p['career_moves']" t-as="m">
                    <tr>
                      <td t-esc="m['type']"/>
                      <td t-esc="m['date']"/>
                      <td t-esc="m['old']"/>
                      <td t-esc="m['new']"/>
                    </tr>
                  </t>
                  <t t-if="not p['career_moves']">
                    <tr><td colspan="4" style="height:35px;"></td></tr>
                  </t>
                </table>
              </td>
            </tr>
          </table>

          <div class="sb-small" style="margin-top:10px; display:flex; justify-content:space-between;">
            <div>
              Printed by <t t-esc="env.user.name"/>
            </div>
            <div>Page 1 of 1</div>
          </div>
        </div>
      </t>
    </t>
  </template>
</cycom>
