<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="paperformat_pos_advance_order_receipt" model="report.paperformat">
        <field name="name">POS Advance Order Receipt</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">200</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">3</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="disable_shrinking" eval="True"/>
    </record>

    <record id="action_report_pos_advance_order_receipt" model="ir.actions.report">
        <field name="name">Advance Order Receipt</field>
        <field name="model">pos.advance.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_advance_order.report_pos_advance_order_receipt</field>
        <field name="report_file">pos_advance_order.report_pos_advance_order_receipt</field>
        <field name="paperformat_id" ref="paperformat_pos_advance_order_receipt"/>
        <field name="print_report_name">'AdvanceOrder-%s' % (object.name)</field>
    </record>

    <record id="action_report_pos_advance_order_full_receipt" model="ir.actions.report">
        <field name="name">Advance Order Full Receipt</field>
        <field name="model">pos.advance.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">pos_advance_order.report_pos_advance_order_full_receipt</field>
        <field name="report_file">pos_advance_order.report_pos_advance_order_full_receipt</field>
        <field name="paperformat_id" ref="paperformat_pos_advance_order_receipt"/>
        <field name="print_report_name">'AdvanceOrderFull-%s' % (object.name)</field>
    </record>
</cycom>

