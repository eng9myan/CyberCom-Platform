<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <template id="report_pos_advance_order_receipt">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <div style="max-width: 80mm; font-family: monospace; font-size: 12px;">
                        <div class="text-center" style="border-bottom: 1px dashed #000; padding-bottom: 6px; margin-bottom: 6px;">
                            <div><strong t-esc="o.company_id.name"/></div>
                            <div>Advance Order Receipt</div>
                            <div t-esc="o.name"/>
                        </div>

                        <div style="margin-bottom: 6px;">
                            <div><strong>Customer:</strong> <span t-esc="o.partner_id.display_name"/></div>
                            <div><strong>Date:</strong> <span t-esc="o.picking_date"/></div>
                        </div>

                        <div style="border-bottom: 1px dashed #000; padding-bottom: 6px; margin-bottom: 6px;">
                            <table style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;">Item</th>
                                        <th style="text-align:right;">Qty</th>
                                        <th style="text-align:right;">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.line_ids.filtered(lambda l: not l.display_type)" t-as="l">
                                        <tr>
                                            <td style="text-align:left;">
                                                <span t-esc="l.product_id.display_name"/>
                                            </td>
                                            <td style="text-align:right;">
                                                <span t-esc="l.product_qty"/>
                                            </td>
                                            <td style="text-align:right;">
                                                <span t-esc="o.currency_id.format(l.price_subtotal)"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div style="border-bottom: 1px dashed #000; padding-bottom: 6px; margin-bottom: 6px;">
                            <div style="display:flex; justify-content:space-between;">
                                <span>Total</span>
                                <span t-esc="o.currency_id.format(o.amount_total)"/>
                            </div>
                            <t t-if="o.pledge_amount and not o.with_employee">
                                <div style="display:flex; justify-content:space-between;">
                                    <span>Pledge Amount</span>
                                    <span t-esc="o.currency_id.format(o.pledge_amount)"/>
                                </div>
                            </t>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Advance Paid</span>
                                <span t-esc="o.currency_id.format(o.amount_paid)"/>
                            </div>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Amount Tendered</span>
                                <span t-esc="o.currency_id.format(o.amount_tendered)"/>
                            </div>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Change Returned</span>
                                <span t-esc="o.currency_id.format(o.change_amount)"/>
                            </div>
                            <div style="display:flex; justify-content:space-between;">
                                <span>Remaining</span>
                                <span t-esc="o.currency_id.format(o.amount_remaining)"/>
                            </div>
                        </div>

                        <div class="text-center">
                            <div>Thank you</div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</cycom>


