<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_advance_order.AdvanceOrderFormPopup" owl="1">
        <Dialog size="'md'" title="'Advance Order Details'">
            <div class="o_pos_advance_popup" t-on-click.stop="">
                <div class="rounded-top px-3 py-2 mb-3 bg-primary text-white">
                    <span class="fw-bold">Advance Order Details</span>
                    <small class="d-block opacity-75">Deposit and picking configuration</small>
                </div>
                <div class="form-group mb-3">
                    <label><strong>From POS</strong></label>
                    <input
                        type="text"
                        class="form-control"
                        t-att-value="currentFromPosName"
                        readonly="readonly"
                    />
                </div>

                <div class="form-group mb-3">
                    <label><strong>Picking POS</strong></label>
                    <select
                        class="form-control"
                        t-att-value="state.picking_pos_config_id"
                        t-on-change="onPickingPosChange"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    >
                        <option value="">-- Select Picking POS --</option>
                        <t t-foreach="state.pos_configs" t-as="cfg" t-key="cfg.id">
                            <option t-att-value="cfg.id" t-esc="cfg.name"/>
                        </t>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label><strong>Pricelist</strong></label>
                    <input
                        type="text"
                        class="form-control"
                        t-att-value="state.pricelist_name"
                        readonly="readonly"
                    />
                </div>

                <div class="form-group mb-3">
                    <label>
                        <strong>Advance Amount <span class="text-danger">*</span></strong>
                    </label>
                    <input
                        type="number"
                        class="form-control"
                        min="0"
                        step="0.01"
                        t-att-value="state.advance_amount"
                        t-on-input="onAdvanceAmountInput"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    />
                </div>

                <div class="form-group mb-3">
                    <label>
                        <strong>Amount Tendered <span class="text-danger">*</span></strong>
                    </label>
                    <input
                        type="number"
                        class="form-control"
                        min="0"
                        step="0.01"
                        t-att-value="state.amount_tendered"
                        t-on-input="onAmountTenderedInput"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    />
                    <small class="form-text text-muted">
                        Customer paid at register (can exceed advance). Drawer and accounting record the advance only; give the customer the rest as change.
                    </small>
                </div>

                <div t-if="changeDueRaw() > 0" class="alert alert-info py-2 mb-3" role="status">
                    <strong>Return to customer:</strong>
                    <span class="ms-1" t-esc="changeDueFmt()"/>
                </div>

                <div class="form-group mb-3">
                    <label><strong>Payment method</strong></label>
                    <div
                        t-if="!state.payment_methods.length"
                        class="alert alert-warning mb-0"
                    >
                        <span t-esc="noEligiblePaymentMethodsText"/>
                    </div>
                    <div t-else="" class="paymentmethods-container mb-0">
                        <div class="paymentmethods d-flex flex-column gap-2">
                            <t t-foreach="state.payment_methods" t-as="pm" t-key="pm.id">
                                <div
                                    role="button"
                                    t-att-class="paymentMethodRowClass(pm)"
                                    t-on-click="() => this.selectPaymentMethod(pm)"
                                >
                                    <div class="payment-method-display d-flex align-items-center gap-2 text-wrap lh-sm">
                                        <img
                                            class="payment-method-icon"
                                            t-att-src="paymentMethodIconSrc(pm)"
                                            alt=""
                                        />
                                        <span class="payment-name" t-esc="pm.name"/>
                                    </div>
                                    <div class="text-end">
                                        <div class="text-muted small" title="Recorded in cash / journal (advance deposit)">
                                            Deposit: <span t-esc="advanceAmountFmt()"/>
                                        </div>
                                        <div t-if="changeDueRaw() > 0" class="text-muted small">
                                            Tendered: <span t-esc="amountTenderedFmt()"/>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>

                <div class="form-check mb-2">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        id="pos_advance_with_employee"
                        t-att-checked="state.with_employee"
                        t-on-change="onWithEmployeeChange"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    />
                    <label class="form-check-label" for="pos_advance_with_employee">
                        With Employee
                    </label>
                </div>

                <div class="form-group mb-3" t-if="state.with_employee">
                    <label><strong>Employee</strong></label>
                    <select
                        class="form-control"
                        t-att-value="state.employee_id"
                        t-on-change="onEmployeeChange"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    >
                        <option value="">-- Select Employee --</option>
                        <t t-foreach="state.employees" t-as="employee" t-key="employee.id">
                            <option t-att-value="employee.id" t-esc="employee.name"/>
                        </t>
                    </select>
                </div>

                <div class="form-group mb-1">
                    <label><strong>Discount (Optional)</strong></label>
                    <select
                        class="form-control"
                        t-att-value="state.discount_id"
                        t-on-change="onDiscountChange"
                        t-att-disabled="state.loading ? 'disabled' : undefined"
                    >
                        <option value="">-- No Discount --</option>
                        <t t-foreach="state.discounts" t-as="discount" t-key="discount.id">
                            <option t-att-value="discount.id">
                                <t t-esc="discount.name"/> -
                                <t t-esc="discountLabelSuffix(discount)"/>
                            </option>
                        </t>
                    </select>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click.stop="cancel">Cancel</button>
                <button class="btn btn-primary" t-on-click.stop="confirm" t-att-disabled="state.loading ? 'disabled' : undefined">
                    Confirm
                </button>
            </t>
        </Dialog>
    </t>
</templates>
