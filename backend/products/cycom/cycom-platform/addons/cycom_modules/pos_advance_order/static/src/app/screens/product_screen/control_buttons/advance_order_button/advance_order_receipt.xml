<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_advance_order.AdvanceOrderReceipt">
        <div class="pos-receipt p-2">
            <div class="text-center">
                <div class="fw-bolder" t-esc="props.receipt.companyName"/>
                <div t-esc="props.receipt.posName"/>
                <div class="pt-1">Advance Order Receipt</div>
            </div>

            <div class="pt-3">
                <div>
                    <strong>Reference:</strong>
                    <span t-esc="props.receipt.reference"/>
                </div>
                <div>
                    <strong>Date:</strong>
                    <span t-esc="props.receipt.date"/>
                </div>
                <div>
                    <strong>Customer:</strong>
                    <span t-esc="props.receipt.customerName"/>
                </div>
                <div t-if="props.receipt.customerPhone">
                    <strong>Phone:</strong>
                    <span t-esc="props.receipt.customerPhone"/>
                </div>
                <div>
                    <strong>Payment:</strong>
                    <span t-esc="paymentMethodLabel"/>
                </div>
            </div>

            <div class="pt-3">
                <div class="d-flex fw-bolder border-bottom pb-1">
                    <span class="w-50">Item</span>
                    <span class="w-25 text-center">Qty</span>
                    <span class="w-25 text-end">Price</span>
                </div>
                <t t-foreach="props.receipt.lines" t-as="line" t-key="line_index">
                    <div class="d-flex pt-1">
                        <span class="w-50 text-break" t-esc="line.name"/>
                        <span class="w-25 text-center" t-esc="line.qty"/>
                        <span class="w-25 text-end" t-esc="formatCurrency(line.subtotal)"/>
                    </div>
                </t>
            </div>

            <div class="pt-3">
                <div class="d-flex">
                    <span>Total</span>
                    <span class="ms-auto" t-esc="formatCurrency(props.receipt.total)"/>
                </div>
                <div class="d-flex">
                    <span>Advance Paid (deposit)</span>
                    <span class="ms-auto" t-esc="formatCurrency(props.receipt.advanceAmount)"/>
                </div>
                <div class="d-flex">
                    <span>Amount Tendered</span>
                    <span class="ms-auto" t-esc="formatCurrency(props.receipt.amountTendered)"/>
                </div>
                <div t-if="props.receipt.changeDue > 0" class="d-flex fw-bolder text-success">
                    <span>Return to customer</span>
                    <span class="ms-auto" t-esc="formatCurrency(props.receipt.changeDue)"/>
                </div>
                <div class="d-flex fw-bolder">
                    <span>Remaining</span>
                    <span class="ms-auto" t-esc="formatCurrency(props.receipt.remainingAmount)"/>
                </div>
            </div>

            <div class="text-center pt-3">
                <span>Thank you</span>
            </div>
        </div>
    </t>
</templates>
