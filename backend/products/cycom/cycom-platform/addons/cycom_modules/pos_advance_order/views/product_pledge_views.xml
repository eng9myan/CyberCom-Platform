<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="product_template_form_view_pos_pledge" model="ir.ui.view">
        <field name="name">product.template.form.pos.pledge</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//group[@name='group_standard_price']" position="after">
                <group string="Pledge">
                    <field name="has_pledge"/>
                    <field name="pledge_amount" widget="monetary" invisible="not has_pledge"/>
                </group>
            </xpath>
        </field>
    </record>
</cycom>

