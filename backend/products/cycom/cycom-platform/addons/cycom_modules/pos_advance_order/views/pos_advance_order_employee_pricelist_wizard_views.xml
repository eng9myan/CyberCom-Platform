<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_pos_advance_order_employee_pricelist_wizard_form" model="ir.ui.view">
        <field name="name">pos.advance.order.employee_pricelist.wizard.form</field>
        <field name="model">pos.advance.order.employee_pricelist.wizard</field>
        <field name="arch" type="xml">
            <form string="Employee Authorization">
                <group>
                    <field name="advance_order_id" readonly="1"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="pos_config_id" readonly="1"/>
                    <field name="employee_pricelist_id" readonly="1"/>
                </group>
                <separator string="Authorization"/>
                <group>
                    <field name="employee_id" readonly="1"/>
                    <!-- The widget is provided by employee_request (web.assets_backend). -->
                    <field name="password" widget="password_eye_char" password="True" required="1"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</cycom>

