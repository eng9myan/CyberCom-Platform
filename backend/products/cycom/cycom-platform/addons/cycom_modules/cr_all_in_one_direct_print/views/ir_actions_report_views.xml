<?xml version="1.0" encoding="utf-8"?>
<cycom>
    
    
    <record id="view_ir_actions_report_form_inherit_print_config" model="ir.ui.view">
        <field name="name">ir.actions.report.form.inherit.print.config</field>
        <field name="model">ir.actions.report</field>
        <field name="inherit_id" ref="base.act_report_xml_view"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="Print Configuration" name="print_configuration"><button name="action_view_print_jobs"
                        string="View Print Jobs"
                        type="object"
                        class="btn-secondary"
                        icon="fa-print"/>

                        <group string="Auto-Print Settings">
                            <field name="auto_print_enabled" widget="boolean_toggle"/>
                            <div colspan="2" class="alert alert-info" role="alert" invisible="auto_print_enabled">
                                <i class="fa fa-info-circle"/> Auto-print is disabled. All printing must be triggered manually for this report.
                            </div>
                            <div colspan="2" class="alert alert-success" role="alert" invisible="not auto_print_enabled">
                                <i class="fa fa-check-circle"/> Auto-print is enabled. This report can trigger automatic printing.
                            </div>
                        </group>
                    
                    <group>
                        <group string="Default Printer Assignment">
                            <field name="default_printer_id" 
                                   options="{'no_create': True}"
                                   context="{'tree_view_ref': 'cr_all_in_one_direct_print.printer_tree_view'}"/>
                            
                        </group>

                    </group>


                </page>
            </xpath>
            
        </field>
    </record>

</cycom>
