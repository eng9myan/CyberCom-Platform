<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="res_config_settings_inherited_direct_print" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.direct_print</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Print Engine" string="Print Engine" name="Print Engine" logo="/cr_all_in_one_direct_print/static/description/icon.png">
                    <block title="Configuration">
                        <group>
                            <group string="Job Retention Policy">
                                <field name="retention_policy" widget="radio"/>
                                <field name="job_retention_days" invisible="retention_policy != 'custom'"/>
                                <div colspan="2" class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle me-1"/> 
                                    Jobs older than 
                                    <field name="job_retention_days" readonly="1" nolabel="1" style="display: inline-block; width: auto; font-weight: bold; margin-bottom: 0; vertical-align: baseline;" class="oe_inline mx-1"/> 
                                    days will be automatically deleted to keep the queue clean and manageable.
                                </div>
                            </group> 
                        </group>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="action_direct_print_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_inherited_direct_print"/>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'Print Engine'}</field>
    </record>

 <menuitem id="menu_print_config_settings"
              parent="menu_printing_configuration"
              name="Settings"
              action="action_direct_print_config_settings"
              sequence="1"/>
</cycom>