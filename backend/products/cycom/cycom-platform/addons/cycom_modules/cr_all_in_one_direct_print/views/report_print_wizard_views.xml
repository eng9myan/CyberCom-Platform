<?xml version="1.0" encoding="utf-8"?>
<cycom>
    
    <!-- Report Print Wizard Form View -->
    <record id="view_report_print_wizard_form" model="ir.ui.view">
        <field name="name">report.print.wizard.form</field>
        <field name="model">report.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Options">
                <group>
                    <field name="report_id" invisible="1"/>
                    <field name="auto_print_enabled" invisible="1"/>
                    <field name="default_printer_id" invisible="1"/>
                    
                    <field name="print_mode" widget="radio"/> 
                </group>
                
                <footer>
                    <button string="Execute" name="action_execute" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    
</cycom>
