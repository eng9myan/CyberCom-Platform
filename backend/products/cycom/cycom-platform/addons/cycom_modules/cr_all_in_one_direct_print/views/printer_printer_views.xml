<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="printer_tree_view" model="ir.ui.view">
        <field name="name">printer.tree.view</field>
        <field name="model">printer.printer</field>
        <field name="arch" type="xml">
            <list string="Printers">
                <field name="name"/>
                <field name="printer_type"/>
                <field name="print_engine_client_id"/>
                <button name="action_test_printer" 
                        type="object" 
                        string="Test Print"
                        icon="fa-print"
                        class="btn-primary"/>
            </list>
        </field>
    </record>
    <record id="printer_form_view" model="ir.ui.view">
        <field name="name">printer.form.view</field>
        <field name="model">printer.printer</field>
        <field name="arch" type="xml">
            <form string="Printer">
                <header>
                    <button name="action_test_printer" 
                            type="object" 
                            string="Test Print"
                            class="btn-primary" icon="fa-print"
                            confirm="This will send a test page to the printer. Continue?"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            </group>
                        <group>
                            <field name="print_engine_client_id"/>
                            <field name="printer_type" widget="radio"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_printer" model="ir.actions.act_window">
        <field name="name">Printers</field>
        <field name="res_model">printer.printer</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_print_hosts"
              parent="menu_printing_root"
              name="Printers"
              action="action_printer"
              sequence="2"/>
</cycom>