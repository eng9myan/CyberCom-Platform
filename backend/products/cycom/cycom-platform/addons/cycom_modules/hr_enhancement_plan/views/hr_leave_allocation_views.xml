<?xml version='1.0' encoding='UTF-8' ?>
<cycom>
    <record id="hr_leave_allocation_view_form_enhancement" model="ir.ui.view">
        <field name="name">hr.leave.allocation.view.form.enhancement</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form"/>
        <field name="arch" type="xml">
            <field name="notes" position="before">
                <field name="last_accrual_calculation_log" invisible="allocation_type == 'regular'"
                    placeholder="Change Start Date, Employee or Accrual Plan to see how the accrual is calculated."/>
            </field>
        </field>
    </record>
</cycom>
