<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_hr_payslip_form_inherit_overtime_quantity" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.cycom.group.overtime</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group[.//field[@name='date_from'] and .//field[@name='date_to']]" position="inside">
                <label for="termination_clearance" string="Termination Clearance / مخالصة تيرمنيشن"/>
                <field name="termination_clearance" nolabel="1"/>
            </xpath>

            <xpath expr="//page[@name='account_info']/group/group[1]" position="inside">
                <field name="employee_extra_hours_balance" widget="float_time" readonly="1"/>
                <field name="overtime_hours_deducted" widget="float_time" readonly="1"/>
            </xpath>

            <xpath expr="//field[@name='input_line_ids']/list/field[@name='amount']" position="before">
                <field name="overtime_quantity_type" column_invisible="True"/>
                <field name="quantity" widget="float_without_trailing_zeros" readonly="0"/>
            </xpath>
            <xpath expr="//field[@name='input_line_ids']/list/field[@name='amount']" position="attributes">
                <attribute name="readonly">overtime_quantity_type</attribute>
            </xpath>

            <xpath expr="//field[@name='input_line_ids']/form/group/field[@name='amount']" position="before">
                <field name="overtime_quantity_type" invisible="1"/>
                <field name="quantity" readonly="0"/>
            </xpath>
            <xpath expr="//field[@name='input_line_ids']/form/group/field[@name='amount']" position="attributes">
                <attribute name="readonly">overtime_quantity_type</attribute>
            </xpath>
        </field>
    </record>
</cycom>
