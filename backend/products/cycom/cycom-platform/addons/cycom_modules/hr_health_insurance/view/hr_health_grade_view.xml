<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="hr_health_grade_list_view" model="ir.ui.view">
        <field name="name">hr.health.grade.list.view</field>
        <field name="model">hr.health.grade</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name" required="1"/>
            </list>
        </field>
    </record>

    <record id="hr_health_grade_search_view" model="ir.ui.view">
        <field name="name">hr.health.grade.search.view</field>
        <field name="model">hr.health.grade</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Grade Name" placeholder='Ex. Grade A'/>
            </search>
        </field>
    </record>

    <record id="action_hr_health_grade" model="ir.actions.act_window">
        <field name="name">Insurance Grades</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.health.grade</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_hr_health_grade"
              name="Insurance Grades"
              parent="menu_hr_health_insurance_master"
              action="action_hr_health_grade"
              sequence="10"/>
</cycom>
