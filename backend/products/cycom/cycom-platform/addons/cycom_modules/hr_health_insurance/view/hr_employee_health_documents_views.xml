<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="hr_employee_view_form_health_documents" model="ir.ui.view">
        <field name="name">hr.employee.form.health.documents</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="before">
                <page name="health_hr_documents" string="Documents" groups="hr.group_hr_user">
                    <field name="health_document_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="document_type_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="probation_start_date" optional="show"/>
                            <field name="document_file" filename="document_filename"/>
                            <field name="document_filename" column_invisible="1"/>
                            <field name="expiry_date"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</cycom>
