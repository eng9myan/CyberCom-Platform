<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_cycom_mobile_device_tree" model="ir.ui.view">
        <field name="name">cycom.mobile.device.tree</field>
        <field name="model">cycom.mobile.device</field>
        <field name="arch" type="xml">
            <list string="Mobile app devices">
                <field name="user_id"/>
                <field name="device_uid"/>
                <field name="device_name"/>
                <field name="token_index"/>
                <field name="active"/>
                <field name="last_login"/>
            </list>
        </field>
    </record>

    <record id="view_cycom_mobile_device_form" model="ir.ui.view">
        <field name="name">cycom.mobile.device.form</field>
        <field name="model">cycom.mobile.device</field>
        <field name="arch" type="xml">
            <form string="Mobile app device">
                <header>
                    <button name="action_reset_device" type="object" string="Reset device" class="btn-primary"
                            confirm="This clears the registered device and token. The user must log in again from the mobile app."/>
                </header>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="device_uid"/>
                        <field name="device_name"/>
                        <field name="token_index" readonly="1"/>
                        <field name="active"/>
                        <field name="last_login" readonly="1"/>
                    </group>
                    <group string="Technical" groups="base.group_system">
                        <field name="token_hash" password="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cycom_mobile_device" model="ir.actions.act_window">
        <field name="name">Mobile app devices</field>
        <field name="res_model">cycom.mobile.device</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_cycom_mobile_device"
        name="Mobile app devices"
        parent="base.menu_users"
        action="action_cycom_mobile_device"
        sequence="95"
        groups="base.group_system"
    />
</cycom>
