<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="res_config_settings_view_form_inherit_weekly_overtime" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.weekly.overtime</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='overtime_settings']" position="inside">
                <setting
                    string="Required Weekly Hours"
                    help="Minimum weekly worked hours an employee must complete before overtime can be approved."
                >
                    <field name="required_weekly_hours" class="text-center" style="width: 5ch;"/>
                    <span class="ms-2">Hours</span>
                </setting>
            </xpath>
        </field>
    </record>
</cycom>
