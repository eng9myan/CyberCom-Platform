<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <template id="portal_layout_dashboard_embed_no_header" inherit_id="portal.portal_layout" priority="120">
        <xpath expr="//t[@t-call='portal.frontend_layout']" position="before">
            <t t-set="is_dashboard_embed"
               t-value="request and request.httprequest and request.httprequest.path.startswith('/my/') and ((request.params.get('from_dashboard') in ('1', 'true', 'True')) or request.httprequest.headers.get('Sec-Fetch-Dest') == 'iframe')"/>
            <!-- Hide website header/offcanvas only for portal pages rendered inside dashboard iframe. -->
            <t t-if="is_dashboard_embed">
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_home_menu_check_in" inherit_id="portal.portal_my_home" priority="999">
        <xpath expr="//div[@id='portal_alert_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_service_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_vendor_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_client_category']" position="attributes">
            <attribute name="t-if">False</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_common_category']" position="replace">
            <div class="o_portal_category row g-2 mt-3" id="portal_common_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                    <t t-set="title">Attendance</t>
                    <t t-set="text">Check in and check out</t>
                    <t t-set="url" t-value="'/cycom/check-in' if request.env.user._is_internal() else '/my/check-in'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                    <t t-set="title">Portal</t>
                    <t t-set="text">Open your employee services dashboard</t>
                    <t t-set="url" t-value="'/my/portal-dashboard'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>

    <template id="portal_breadcrumbs_check_in" inherit_id="portal.portal_breadcrumbs">
        <xpath expr="//ol" position="inside">
            <li t-if="page_name == 'my_check_in'" class="breadcrumb-item">Attendance</li>
            <li t-if="page_name == 'portal_dashboard'" class="breadcrumb-item">Portal Dashboard</li>
        </xpath>
    </template>

    <template id="portal_dashboard" name="Portal Employee Dashboard">
        <t t-call="portal.portal_layout">
            <style>
                .o_portal_dashboard_wrapper {
                    margin-top: 1.5rem;
                    margin-bottom: 1.5rem;
                }
                .o_portal_dashboard_title {
                    background: #fff;
                    border-radius: 16px;
                    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
                    padding: 1rem 1.25rem;
                    margin-bottom: 1rem;
                }
                .o_portal_dashboard_layout {
                    display: grid;
                    grid-template-columns: 24% 76%;
                    gap: 1rem;
                    align-items: start;
                }
                .o_portal_dashboard_sidebar {
                    width: 100%;
                    min-height: 70vh;
                    max-height: 78vh;
                    overflow-y: auto;
                    background: #fff;
                    border-radius: 16px;
                    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
                    padding: 1rem 0.75rem;
                }
                .o_portal_dashboard_sidebar_title {
                    font-size: 1rem;
                    font-weight: 700;
                    color: #0f172a;
                    padding: 0 0.75rem 0.75rem;
                    margin-bottom: 0.25rem;
                    border-bottom: 1px solid #e2e8f0;
                }
                .o_portal_dashboard_nav_item {
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    border-radius: 10px;
                    padding: 0.7rem 0.75rem;
                    color: #334155;
                    text-decoration: none;
                    font-weight: 500;
                    transition: all 0.2s ease;
                }
                .o_portal_dashboard_nav_item i {
                    width: 1rem;
                    text-align: center;
                }
                .o_portal_dashboard_nav_item:hover {
                    background: #f8fafc;
                    color: #0f172a;
                }
                .o_portal_dashboard_nav_item.is-active {
                    background: #eff6ff;
                    color: #1d4ed8;
                    box-shadow: inset 0 0 0 1px #bfdbfe;
                }
                .o_portal_dashboard_content {
                    min-width: 0;
                    flex: 1 1 auto;
                    background: #fff;
                    border-radius: 16px;
                    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
                    padding: 1rem;
                    display: flex;
                    flex-direction: column;
                }
                .o_portal_dashboard_content_header {
                    border-bottom: 1px solid #e2e8f0;
                    padding-bottom: 0.8rem;
                    margin-bottom: 0.9rem;
                }
                .o_portal_dashboard_iframe_wrap {
                    flex: 1 1 auto;
                    min-height: 70vh;
                    overflow: hidden;
                }
                .o_portal_dashboard_iframe {
                    width: 100%;
                    min-height: 70vh;
                    height: 70vh;
                    border: 0;
                    border-radius: 12px;
                    background: #fff;
                }
                @media (max-width: 991.98px) {
                    .o_portal_dashboard_layout {
                        display: block;
                    }
                    .o_portal_dashboard_sidebar {
                        min-height: auto;
                        margin-bottom: 0.75rem;
                    }
                    .o_portal_dashboard_content {
                        padding: 0.85rem;
                    }
                    .o_portal_dashboard_iframe_wrap,
                    .o_portal_dashboard_iframe {
                        min-height: 62vh;
                    }
                }
            </style>
            <div class="container o_portal_dashboard_wrapper">
                <div class="o_portal_dashboard_title">
                    <h4 class="mb-0">Employee Portal</h4>
                </div>
                <div class="o_portal_dashboard_layout">
                    <aside class="o_portal_dashboard_sidebar">
                        <div class="o_portal_dashboard_sidebar_title">Menu</div>
                        <a
                            t-foreach="portal_dashboard_sections"
                            t-as="item"
                            t-key="item['key']"
                            t-attf-class="o_portal_dashboard_nav_item #{'is-active' if item['active'] else ''}"
                            t-att-href="'/my/portal-dashboard?section=%s' % item['key']"
                            t-att-data-section-key="item['key']"
                            t-att-data-content-url="item['url']"
                        >
                            <i t-attf-class="fa #{item['icon']}"/>
                            <span t-esc="item['label']"/>
                        </a>
                    </aside>
                    <section class="o_portal_dashboard_content">
                        <div class="o_portal_dashboard_content_header">
                            <h4 class="mb-0" id="o_portal_dashboard_title" t-esc="portal_dashboard_selected_label"/>
                        </div>
                        <div class="o_portal_dashboard_iframe_wrap">
                            <!-- Keep all existing business logic untouched by reusing existing routes in an iframe shell. -->
                            <iframe
                                id="o_portal_dashboard_iframe"
                                class="o_portal_dashboard_iframe"
                                t-att-src="portal_dashboard_selected_url"
                                t-att-title="portal_dashboard_selected_label"
                                scrolling="no"
                            />
                        </div>
                    </section>
                </div>
            </div>
            <script type="text/javascript">
                (function () {
                    function setupPortalDashboardNavigation() {
                        var wrapper = document.querySelector('.o_portal_dashboard_wrapper');
                        if (!wrapper) {
                            return;
                        }
                        var iframe = wrapper.querySelector('#o_portal_dashboard_iframe');
                        var title = wrapper.querySelector('#o_portal_dashboard_title');
                        var navItems = wrapper.querySelectorAll('.o_portal_dashboard_nav_item');
                        if (!iframe || !title || !navItems.length) {
                            return;
                        }

                        function resizeIframe() {
                            try {
                                var doc = iframe.contentDocument || (iframe.contentWindow &amp;&amp; iframe.contentWindow.document);
                                if (!doc) {
                                    return;
                                }
                                var bodyHeight = doc.body ? doc.body.scrollHeight : 0;
                                var htmlHeight = doc.documentElement ? doc.documentElement.scrollHeight : 0;
                                var finalHeight = Math.max(bodyHeight, htmlHeight, 720);
                                iframe.style.height = String(finalHeight) + 'px';
                            } catch (error) {
                                // Cross-frame guards: keep default height if document is not accessible.
                            }
                        }

                        function setActive(clickedItem) {
                            navItems.forEach(function (item) {
                                item.classList.toggle('is-active', item === clickedItem);
                            });
                        }

                        iframe.addEventListener('load', function () {
                            resizeIframe();
                            setTimeout(resizeIframe, 250);
                            setTimeout(resizeIframe, 900);
                        });

                        navItems.forEach(function (item) {
                            item.addEventListener('click', function (event) {
                                var url = item.getAttribute('data-content-url');
                                if (!url) {
                                    return;
                                }
                                event.preventDefault();
                                iframe.setAttribute('src', url);
                                title.textContent = item.textContent.trim();
                                setActive(item);
                                if (window.history &amp;&amp; window.history.replaceState) {
                                    window.history.replaceState({}, '', item.getAttribute('href'));
                                }
                            });
                        });

                        resizeIframe();
                    }

                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', setupPortalDashboardNavigation);
                    } else {
                        setupPortalDashboardNavigation();
                    }
                })();
            </script>
        </t>
    </template>

    <template id="portal_my_check_in" name="Portal Attendance Check In">
        <t t-call="portal.portal_layout">
            <style>
                .pc-check-card {
                    max-width: 420px;
                    margin: 0 auto;
                    border: 0;
                    border-radius: 18px;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
                }
                .pc-check-head {
                    font-size: 1.9rem;
                    font-weight: 700;
                    line-height: 1.2;
                }
                .pc-check-circle-wrap {
                    display: flex;
                    justify-content: center;
                    margin: 1rem 0 1.5rem;
                }
                .pc-check-circle-btn {
                    width: 170px;
                    height: 170px;
                    border-radius: 50%;
                    border: 0;
                    color: #fff;
                    font-weight: 700;
                    letter-spacing: 0.03em;
                    box-shadow: 0 8px 22px rgba(189, 73, 157, 0.45);
                    background: linear-gradient(145deg, #7e4cd6, #e44789);
                }
                .pc-check-circle-btn i {
                    display: block;
                    font-size: 2rem;
                    margin-bottom: 0.4rem;
                }
                .pc-check-stats {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 0.5rem;
                    text-align: center;
                }
                .pc-check-stat-value {
                    font-weight: 700;
                    font-size: 1rem;
                }
                .pc-check-stat-label {
                    color: #6c757d;
                    font-size: 0.78rem;
                }
                .pc-check-history td, .pc-check-history th {
                    font-size: 0.84rem;
                    padding-top: 0.45rem;
                    padding-bottom: 0.45rem;
                }
            </style>
            <div class="container">
                <input type="hidden" id="o_portal_location_permission_msg" t-att-value="location_permission_required"/>
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-6">
                        <div class="card pc-check-card">
                            <div class="card-body p-4">
                                <div class="text-muted" t-esc="txt_hello"/>
                                <div class="pc-check-head mb-2">
                                    <t t-esc="employee.name if employee else request.env.user.name"/>
                                </div>
                                <div class="mb-3 text-end">
                                    <a href="/my/overtime_approvals" class="btn btn-outline-primary btn-sm">
                                        <t t-esc="txt_overtime_approvals_btn"/>
                                    </a>
                                </div>
                                <div t-if="show_success" class="alert alert-success py-2" role="alert">
                                    <t t-esc="txt_attendance_updated"/>
                                </div>
                                <div t-if="show_no_employee or not employee" class="alert alert-warning py-2" role="alert">
                                    <t t-esc="txt_no_employee"/>
                                </div>
                                <div t-if="show_location_restricted" class="alert alert-danger py-2 o_portal_location_restricted_alert" role="alert">
                                    <t t-esc="location_restricted_message or txt_location_default"/>
                                </div>
                                <div t-if="employee and weekly_gate_reached and state != 'checked_in' and not available_overtime_authorization" class="alert alert-warning py-2" role="alert">
                                    <span><t t-esc="txt_weekly_threshold"/> </span>
                                    (<t t-esc="'%0.2f' % (weekly_worked_hours or 0.0)"/> /
                                    <t t-esc="'%0.2f' % (required_weekly_hours or 0.0)"/>).
                                    <span> <t t-esc="txt_checkin_locked_ot"/></span>
                                </div>
                                <div t-if="employee and weekly_gate_reached and state != 'checked_in' and available_overtime_authorization" class="alert alert-success py-2" role="status">
                                    <span><t t-esc="txt_ot_auth_session"/> </span>
                                    <span><t t-esc="txt_max_auth_hours"/> </span>
                                    <span><t t-esc="'%0.2f' % (available_overtime_authorization.quantity or 0.0)"/>.</span>
                                </div>
                                <t t-if="employee">
                                    <div class="pc-check-circle-wrap">
                                        <form id="checkin_form" t-att-action="toggle_url" method="post" class="o_portal_check_in_form" t-att-data-device-tracking-enabled="'1' if device_tracking_enabled else '0'">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="latitude" id="lat" class="o_portal_check_latitude"/>
                                            <input type="hidden" name="longitude" id="lon" class="o_portal_check_longitude"/>
                                            <button type="button" class="pc-check-circle-btn" onclick="submitCheckIn()" t-att-disabled="'disabled' if (weekly_gate_reached and state != 'checked_in' and not available_overtime_authorization) else None">
                                                <i class="fa fa-hand-pointer-o"/>
                                                <t t-if="state == 'checked_in'"><t t-esc="txt_check_out_btn"/></t>
                                                <t t-else=""><t t-esc="txt_check_in_btn"/></t>
                                            </button>
                                        </form>
                                    </div>
                                    <div class="pc-check-stats mb-3">
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <span t-if="today_check_in" t-esc="today_check_in"/>
                                                <span t-else="">-/-</span>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_stat_check_in"/></div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <span t-if="today_check_out" t-esc="today_check_out"/>
                                                <span t-else="">-/-</span>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_stat_check_out"/></div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <t t-esc="hours_today_display"/>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_working_hours"/></div>
                                        </div>
                                    </div>
                                    <div class="pc-check-stats mb-3">
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <t t-esc="'%0.2f' % (weekly_worked_hours or 0.0)"/>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_weekly_worked"/></div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <t t-esc="'%0.2f' % (required_weekly_hours or 0.0)"/>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_weekly_limit"/></div>
                                        </div>
                                        <div>
                                            <div class="pc-check-stat-value">
                                                <span t-if="available_overtime_authorization"><t t-esc="txt_approved"/></span>
                                                <span t-else=""><t t-esc="txt_none"/></span>
                                            </div>
                                            <div class="pc-check-stat-label"><t t-esc="txt_ot_approval"/></div>
                                        </div>
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-sm mb-0 pc-check-history">
                                            <thead>
                                                <tr>
                                                    <th><t t-esc="txt_hist_check_in"/></th>
                                                    <th><t t-esc="txt_hist_check_out"/></th>
                                                    <th><t t-esc="txt_hist_hours"/></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="recent_attendances" t-as="att">
                                                    <td><span t-field="att.check_in" t-options='{"format": "HH:mm"}'/></td>
                                                    <td>
                                                        <span t-if="att.check_out" t-field="att.check_out" t-options='{"format": "HH:mm"}'/>
                                                        <span t-else="">-/-</span>
                                                    </td>
                                                    <td><t t-esc="'%0.2f' % (att.worked_hours or 0.0)"/></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                (function () {
                    var isSubmitting = false;

                    function showLocationBlockedAlert() {
                        var locationBlockedAlert = document.querySelector('.o_portal_location_restricted_alert');
                        if (locationBlockedAlert) {
                            window.alert(locationBlockedAlert.textContent.trim());
                        }
                    }

                    window.submitCheckIn = function () {
                        if (isSubmitting) {
                            return;
                        }

                        var form = document.getElementById('checkin_form');
                        if (!form) {
                            return;
                        }

                        var button = form.querySelector('button');
                        var latitudeInput = document.getElementById('lat');
                        var longitudeInput = document.getElementById('lon');
                        var trackingEnabled = form.dataset.deviceTrackingEnabled === '1';

                        function submitForm() {
                            isSubmitting = true;
                            if (button) {
                                button.disabled = true;
                            }
                            form.submit();
                        }

                        if (!trackingEnabled) {
                            submitForm();
                            return;
                        }

                        var locationMsgEl = document.getElementById('o_portal_location_permission_msg');
                        var locationMsg = locationMsgEl &amp;&amp; locationMsgEl.value ? locationMsgEl.value : 'Location permission required';

                        if (!navigator.geolocation || !navigator.onLine) {
                            window.alert(locationMsg);
                            return;
                        }

                        navigator.geolocation.getCurrentPosition(
                            function (position) {
                                latitudeInput.value = String(position.coords.latitude || '');
                                longitudeInput.value = String(position.coords.longitude || '');
                                submitForm();
                            },
                            function () {
                                window.alert(locationMsg);
                            },
                            {
                                enableHighAccuracy: true,
                                timeout: 10000,
                                maximumAge: 0,
                            }
                        );
                    };

                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', showLocationBlockedAlert);
                    } else {
                        showLocationBlockedAlert();
                    }
                })();
            </script>
        </t>
    </template>
</cycom>
