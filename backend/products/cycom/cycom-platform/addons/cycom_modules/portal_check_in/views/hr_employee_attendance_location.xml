<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_employee_form_remote_attendance_portal_check_in" model="ir.ui.view">
        <field name="name">hr.employee.form.remote.attendance.portal.check.in</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority" eval="96"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']" position="inside">
                <group string="Attendance Location">
                    <field name="allow_remote_attendance"/>
                </group>
            </xpath>
        </field>
    </record>
</cycom>
