<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="view_employee_form_allow_portal_users" model="ir.ui.view">
        <field name="name">hr.employee.form.allow.portal.users</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority" eval="95"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='hr_settings']//field[@name='user_id'][@groups='base.group_erp_manager']"
                   position="attributes">
                <attribute name="context">
                    {
                        'default_create_employee_id': id,
                        'default_name': name,
                        'default_phone': work_phone,
                        'default_mobile': mobile_phone,
                        'default_login': work_email,
                        'default_partner_id': work_contact_id
                    }
                </attribute>
            </xpath>
            <xpath expr="//page[@name='hr_settings']//field[@name='user_id'][@groups='!base.group_erp_manager']"
                   position="attributes">
                <attribute name="context">
                    {
                        'default_create_employee_id': id,
                        'default_name': name,
                        'default_phone': work_phone,
                        'default_mobile': mobile_phone,
                        'default_login': work_email,
                        'default_partner_id': work_contact_id
                    }
                </attribute>
            </xpath>
        </field>
    </record>
</cycom>
