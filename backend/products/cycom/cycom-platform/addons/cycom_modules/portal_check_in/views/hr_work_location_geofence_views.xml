<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="hr_work_location_form_view_attendance_geofence" model="ir.ui.view">
        <field name="name">hr.work.location.form.attendance.geofence</field>
        <field name="model">hr.work.location</field>
        <field name="inherit_id" ref="hr.hr_work_location_form_view"/>

        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_type']" position="after">
                <group string="Attendance Geofence">
                    <field name="attendance_geo_enforce"/>
                    <field name="attendance_geo_latitude" invisible="not attendance_geo_enforce"/>
                    <field name="attendance_geo_longitude" invisible="not attendance_geo_enforce"/>
                    <field name="attendance_geo_radius_m" invisible="not attendance_geo_enforce"/>
                </group>
            </xpath>
        </field>
    </record>
</cycom>
