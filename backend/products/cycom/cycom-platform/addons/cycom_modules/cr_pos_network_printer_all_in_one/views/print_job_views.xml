<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <!-- Inherit list view -->
    <record id="pos_print_job_list_view_inherit" model="ir.ui.view">
        <field name="name">pos.print.job.list.view.inherit</field>
        <field name="model">print.job</field>
        <field name="inherit_id" ref="cr_all_in_one_direct_print.print_job_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='printer_name']" position="after">
                <field name="ip" optional="show"/>
                <field name="port" optional="hide"/>
                <field name="printer_type" optional="show"/>
                <field name="is_open_cashbox" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit form view -->
    <record id="pos_print_job_form_view_inherit" model="ir.ui.view">
        <field name="name">pos.print.job.form.view.inherit</field>
        <field name="model">print.job</field>
        <field name="inherit_id" ref="cr_all_in_one_direct_print.print_job_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='print_type']" position="after">
                <field name="ip" invisible="printer_type == 'usb'"/>
                <field name="port" invisible="printer_type == 'usb'"/>
                <field name="printer_type"/>
                <field name="is_open_cashbox"/>
            </xpath>
        </field>
    </record>
</cycom>
