<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <!-- Inherit list view -->
    <record id="pos_printer_tree_view_inherit" model="ir.ui.view">
        <field name="name">pos.printer.tree.view.inherit</field>
        <field name="model">printer.printer</field>
        <field name="inherit_id" ref="cr_all_in_one_direct_print.printer_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='printer_type']" position="after">
                <field name="ip" optional="show"/>
                <field name="port" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit form view -->
    <record id="pos_printer_form_view_inherit" model="ir.ui.view">
        <field name="name">pos.printer.form.view.inherit</field>
        <field name="model">printer.printer</field>
        <field name="inherit_id" ref="cr_all_in_one_direct_print.printer_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="ip" invisible="printer_type != 'network'" required="printer_type == 'network'"/>
                <field name="port" invisible="printer_type != 'network'" required="printer_type == 'network'"/>
            </xpath>
        </field>
    </record>
</cycom>