<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pos_pledge.EmployeeSelectionPopup" owl="1">
        <Dialog title="'Select Employee'" size="'md'">
            <div class="employee-selection-popup">
                <!-- Search Bar -->
                <div class="search-bar mb-3">
                    <input
                        type="text"
                        class="form-control"
                        placeholder="Search employee by name or job title..."
                        t-model="state.search"
                        t-on-input="(ev) => this.onSearchInput(ev)"
                        t-on-keydown="(ev) => this.onSearchKeydown(ev)"
                        autofocus="autofocus"
                    />
                </div>

                <!-- Employee List -->
                <div class="employee-list" style="max-height: 400px; overflow-y: auto;">
                    <t t-if="filteredEmployees.length === 0">
                        <div class="text-center p-4 text-muted">
                            <i class="fa fa-user-times fa-2x mb-2"/>
                            <p>No employees found</p>
                        </div>
                    </t>

                    <t t-foreach="filteredEmployees" t-as="employee" t-key="employee.id">
                        <div
                            class="employee-item p-3 mb-2 border rounded cursor-pointer"
                            t-on-click="() => this.selectEmployee(employee)"
                            style="transition: background-color 0.2s;"
                            t-attf-class="employee-item p-3 mb-2 border rounded cursor-pointer #{state.selectedEmployee and state.selectedEmployee.id === employee.id ? 'bg-primary text-white' : 'bg-white'}"
                        >
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong t-esc="employee.name"/>
                                    <t t-if="employee.job_title">
                                        <br/>
                                        <small class="text-muted">
                                            <t t-esc="Array.isArray(employee.job_title) ? employee.job_title[1] : employee.job_title"/>
                                        </small>
                                    </t>
                                </div>
                                <i class="fa fa-chevron-right"/>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Footer Buttons -->
                <div class="d-flex justify-content-end mt-3">
                    <button
                        class="btn btn-secondary me-2"
                        t-on-click="() => this.cancel()"
                    >
                        Cancel
                    </button>
                </div>
            </div>
        </Dialog>
    </t>

</templates>
