<?xml version="1.0" encoding="utf-8"?>
<cycom>
    
    <!-- Extend POS Config Form -->
    <record id="pos_config_view_form_pledge" model="ir.ui.view">
        <field name="name">pos.config.form.pledge</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            
            <!-- Add Pledge Configuration Section -->
            <xpath expr="//sheet" position="inside">
                <group string="Pledge (Rahn) Configuration" name="pledge_configuration">
                    <group>
                        <field name="pledge_product_id"/>
                        <field name="pos_pledge_liability_account_id"/>
                    </group>
                    <group>
                        <div class="alert alert-info" role="status" colspan="2">
                            <strong>Note:</strong> Orders with pledge items will NOT automatically create customer invoices. 
                            Pledge orders will be tracked in the pledge menu automatically.
                        </div>
                    </group>
                </group>
            </xpath>
            
        </field>
    </record>

</cycom>
