<?xml version="1.0" encoding="utf-8"?>
<cycom>
    
    <!-- Extend Product Template Form -->
    <record id="product_template_form_view_pledge" model="ir.ui.view">
        <field name="name">product.template.form.pledge</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            
            <!-- Add Pledge Configuration Section -->
            <xpath expr="//notebook/page[@name='sales']" position="inside">
                <group string="Pledge (Rahn) Configuration" name="pledge_config">
                    <group>
                        <field name="is_plege"/>
                        <field name="pledge_amount" invisible="not is_plege"/>
                    </group>
                    <group>
                        <field name="is_employee_service"/>
                        <field name="is_delivery_product"/>
                    </group>
                </group>
            </xpath>
            
        </field>
    </record>

</cycom>
