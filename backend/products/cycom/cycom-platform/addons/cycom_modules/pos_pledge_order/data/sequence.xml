<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <data noupdate="1">
        
        <!-- Sequence for POS Pledge References -->
        <record id="seq_pos_pledge" model="ir.sequence">
            <field name="name">POS Pledge Sequence</field>
            <field name="code">pos.pledge</field>
            <field name="prefix">PLEDGE/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>
        
    </data>
</cycom>

