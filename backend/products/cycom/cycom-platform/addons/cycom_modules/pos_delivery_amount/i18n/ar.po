#. module: pos_delivery_amount
msgid "Delivery Amount"
msgstr "مبلغ التوريد"

#. module: pos_delivery_amount
msgid "Delivery Intermediate Account"
msgstr "الحساب الوسيط"

#. module: pos_delivery_amount
msgid "Delivery Journal"
msgstr "دفتر يومية التوريد"

#. module: pos_delivery_amount
msgid "Delivery Journal Entry"
msgstr "قيد يومية التوريد"

#. module: pos_delivery_amount
msgid "Delivery Amount cannot exceed counted cash balance."
msgstr "لا يمكن أن يكون مبلغ التوريد أكبر من الرصيد النقدي الفعلي."

#. module: pos_delivery_amount
msgid "Are you sure the Delivery Amount is zero?"
msgstr "هل أنت متأكد أن مبلغ التوريد يساوي صفر؟"

#. module: pos_delivery_amount
msgid "Delivery Amount processed successfully.<br/>Delivery Amount: %(amount)s<br/>User: %(user)s<br/>Journal Entry: %(move)s<br/>Date/Time: %(date)s"
msgstr "تمت معالجة مبلغ التوريد بنجاح.<br/>مبلغ التوريد: %(amount)s<br/>المستخدم: %(user)s<br/>قيد اليومية: %(move)s<br/>التاريخ/الوقت: %(date)s"

#. module: pos_delivery_amount
msgid "Delivery Amount must be positive or zero."
msgstr "يجب أن يكون مبلغ التوريد أكبر من أو يساوي الصفر."

#. module: pos_delivery_amount
msgid "Counted Cash Balance"
msgstr "الرصيد النقدي الفعلي"

#. module: pos_delivery_amount
msgid "Yes"
msgstr "نعم"

#. module: pos_delivery_amount
msgid "No"
msgstr "لا"
