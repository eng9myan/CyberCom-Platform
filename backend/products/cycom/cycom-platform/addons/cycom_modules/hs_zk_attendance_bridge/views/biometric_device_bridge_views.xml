<?xml version="1.0" encoding="UTF-8" ?>
<cycom>
    <record id="biometric_device_bridge_view_list" model="ir.ui.view">
        <field name="name">biometric.device.bridge.view.list</field>
        <field name="model">biometric.device.bridge</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_identifier"/>
                <field name="company_id"/>
                <field name="last_sync_at"/>
                <field name="last_request_summary"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="biometric_device_bridge_view_form" model="ir.ui.view">
        <field name="name">biometric.device.bridge.view.form</field>
        <field name="model">biometric.device.bridge</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_regenerate_token"
                        string="Regenerate Token"
                        type="object"
                        class="btn-secondary"
                        confirm="The local bridge agent must be updated after changing the token. Continue?"
                    />
                    <button
                        name="action_view_logs"
                        string="Attendance Logs"
                        type="object"
                        class="oe_highlight"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="device_identifier"/>
                            <field name="device_timezone"/>
                            <field name="import_from_date"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="access_token" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                            <field name="last_request_at" readonly="1"/>
                            <field name="log_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="last_request_summary" readonly="1"/>
                    </group>
                    <group string="Bridge Endpoint">
                        <div class="o_form_label">POST /hs_zk_attendance_bridge/push</div>
                        <div class="text-muted">
                            Send JSON with keys: <code>token</code>, <code>device_identifier</code>, and <code>records</code>.
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="biometric_device_bridge_action" model="ir.actions.act_window">
        <field name="name">Bridge Devices</field>
        <field name="res_model">biometric.device.bridge</field>
        <field name="view_mode">list,form</field>
    </record>
</cycom>
