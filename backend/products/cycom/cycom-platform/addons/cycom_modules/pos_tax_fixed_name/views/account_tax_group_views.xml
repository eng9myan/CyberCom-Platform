<?xml version="1.0" encoding="UTF-8"?>
<cycom>
    <record id="view_tax_group_form_pos_fixed_name_inherit" model="ir.ui.view">
        <field name="name">account.tax.group.form.pos.fixed.name.inherit</field>
        <field name="model">account.tax.group</field>
        <field name="inherit_id" ref="account.view_tax_group_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="pos_fixed_group_name" placeholder="Tax 16%"/>
            </xpath>
        </field>
    </record>
</cycom>
