<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="stock_transfer_discrepancy_action" model="ir.actions.act_window">
        <field name="name">Transfer Discrepancies</field>
        <field name="res_model">stock.transfer.discrepancy</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="menu_stock_transfer_discrepancy_root"
        name="Transfer Discrepancies"
        parent="stock.menu_stock_warehouse_mgmt"
        action="stock_transfer_discrepancy_action"
        sequence="90"
        groups="stock.group_stock_user"
    />

    <record id="stock_transfer_discrepancy_view_tree" model="ir.ui.view">
        <field name="name">stock.transfer.discrepancy.tree</field>
        <field name="model">stock.transfer.discrepancy</field>
        <field name="arch" type="xml">
            <list string="Transfer Discrepancies" create="false">
                <field name="date"/>
                <field name="validated_at"/>
                <field name="investigation_deadline"/>
                <field name="picking_id"/>
                <field name="destination_location_id"/>
                <field name="truck_location_id"/>
                <field name="product_id"/>
                <field name="expected_qty"/>
                <field name="actual_qty"/>
                <field name="difference_qty"/>
                <field name="resolved_qty"/>
                <field name="stage"/>
                <field name="state"/>
                <field name="responsible_user_id"/>
            </list>
        </field>
    </record>

    <record id="stock_transfer_discrepancy_view_form" model="ir.ui.view">
        <field name="name">stock.transfer.discrepancy.form</field>
        <field name="model">stock.transfer.discrepancy</field>
        <field name="arch" type="xml">
            <form string="Transfer Discrepancy">
                <header>
                    <button name="%(stock_transfer_discrepancy_new.action_report_stock_transfer_discrepancy)d" type="action" string="Print Report" class="oe_highlight" icon="fa-print"/>
                    <button name="action_create_scrap" type="object" string="Create Scrap Order" invisible="state == 'settled'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="validated_at"/>
                            <field name="investigation_deadline"/>
                            <field name="picking_id"/>
                            <field name="destination_location_id"/>
                            <field name="truck_location_id"/>
                            <field name="product_id"/>
                            <field name="stage"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="expected_qty"/>
                            <field name="actual_qty"/>
                            <field name="difference_qty" readonly="1"/>
                            <field name="resolved_qty" readonly="1"/>
                            <field name="responsible_user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="Enter discrepancy reason..." nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</cycom>
