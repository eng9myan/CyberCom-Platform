<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="approval_request_view_form_overtime_bridge" model="ir.ui.view">
        <field name="name">approval.request.view.form.overtime.bridge</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='request_details']" position="inside">
                <field name="is_overtime_request" invisible="1"/>
                <field name="is_overtime_category" invisible="1"/>
                <field name="overtime_employee_id" readonly="request_status != 'new'" invisible="not is_overtime_category"/>
                <field name="overtime_date_from" readonly="request_status != 'new'" invisible="not is_overtime_category"/>
                <field name="overtime_date_to" readonly="request_status != 'new'" invisible="not is_overtime_category"/>
                <field name="quantity" string="Requested Overtime Hours" readonly="request_status != 'new'" invisible="not is_overtime_category"/>
                <field name="overtime_total_hours" readonly="1" invisible="not is_overtime_category" widget="float_time"/>
                <field name="overtime_preauthorization" readonly="1" invisible="not is_overtime_category"/>
                <field name="overtime_authorization_state" readonly="1" invisible="not overtime_preauthorization"/>
                <field name="overtime_authorized_attendance_id" readonly="1" invisible="not overtime_preauthorization"/>
                <field name="overtime_pending_hours" readonly="1" invisible="not is_overtime_category" widget="float_time"/>
                <field name="overtime_converted_hours" readonly="1" invisible="not is_overtime_category" widget="float_time"/>
                <field name="overtime_expired_hours" readonly="1" invisible="not is_overtime_category" widget="float_time"/>
            </xpath>
            <xpath expr="//page[@name='description']" position="before">
                <page string="Overtime Lines" name="overtime_lines" invisible="not is_overtime_category">
                    <field name="overtime_line_ids" readonly="1">
                        <list create="0" edit="0" delete="0">
                            <field name="employee_id"/>
                            <field name="date"/>
                            <field name="time_start"/>
                            <field name="time_stop"/>
                            <field name="manual_duration" widget="float_time"/>
                            <field name="status" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="approval_request_view_tree_overtime_bridge" model="ir.ui.view">
        <field name="name">approval.request.view.list.overtime.bridge</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='request_status']" position="before">
                <field name="overtime_employee_id" optional="hide"/>
                <field name="overtime_total_hours" optional="hide" widget="float_time"/>
                <field name="overtime_pending_hours" optional="hide" widget="float_time"/>
                <field name="overtime_authorization_state" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="approval_search_view_search_overtime_bridge" model="ir.ui.view">
        <field name="name">approval.request.search.overtime.bridge</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_search_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_approved_requests']" position="before">
                <filter string="Overtime Requests" name="filter_overtime_requests" domain="[('category_id.is_overtime_category', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <record id="approval_category_view_form_overtime_bridge" model="ir.ui.view">
        <field name="name">approval.category.form.overtime.bridge</field>
        <field name="model">approval.category</field>
        <field name="inherit_id" ref="approvals.approval_category_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='option_settings']/field[@name='has_quantity']" position="after">
                <field name="is_overtime_category"/>
            </xpath>
        </field>
    </record>
</cycom>

