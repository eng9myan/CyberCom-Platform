<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <record id="hr_attendance_view_form_overtime_bridge" model="ir.ui.view">
        <field name="name">hr.attendance.form.overtime.bridge</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='linked_overtime_ids']/list/field[@name='status']" position="after">
                <field name="approval_request_ids" widget="many2many_tags" readonly="1" optional="hide"/>
            </xpath>
        </field>
    </record>
</cycom>

