<?xml version="1.0" encoding="utf-8"?>
<cycom>
    <template id="portal_overtime_no_employee" name="Overtime portal: no employee">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="True"/>
            <div class="container py-4">
                <div t-if="error_message" class="alert alert-warning" role="alert">
                    <span t-out="error_message"/>
                </div>
                <a href="/my" class="btn btn-secondary">Back to My Account</a>
            </div>
        </t>
    </template>

    <template id="portal_overtime_list" name="Overtime portal: list">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Overtime approvals</t>
            </t>
            <div class="mb-3">
                <a href="/my/overtime_approvals/new" class="btn btn-primary">New request</a>
                <a href="/my" class="btn btn-link">My account</a>
            </div>
            <div t-if="success_message" class="alert alert-success" role="status">
                <span t-out="success_message"/>
            </div>
            <div t-if="error_message" class="alert alert-danger" role="alert">
                <span t-out="error_message"/>
            </div>
            <div t-if="not overtime_requests" class="alert alert-info" role="status">
                You have no overtime approval requests yet.
            </div>
            <t t-if="overtime_requests" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Subject</th>
                        <th class="text-end">Period</th>
                        <th class="text-end">Requested hours</th>
                        <th class="text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="overtime_requests" t-as="req">
                        <td>
                            <a t-attf-href="/my/overtime_approvals/{{ req.id }}">
                                <t t-out="req.name"/>
                            </a>
                        </td>
                        <td class="text-end text-nowrap">
                            <span t-field="req.overtime_date_from"/>
                            —
                            <span t-field="req.overtime_date_to"/>
                        </td>
                        <td class="text-end">
                            <span t-field="req.quantity"/>
                        </td>
                        <td class="text-center">
                            <span t-field="req.request_status"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </t>
    </template>

    <template id="portal_overtime_new" name="Overtime portal: new request">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">New overtime approval</t>
            </t>
            <div class="mb-3">
                <a href="/my/overtime_approvals" class="btn btn-link">Back to list</a>
            </div>
            <div t-if="success_message" class="alert alert-success" role="status">
                <span t-out="success_message"/>
            </div>
            <div t-if="error_message" class="alert alert-danger" role="alert">
                <span t-out="error_message"/>
            </div>
            <div t-if="not categories" class="alert alert-warning" role="alert">
                No overtime approval type is configured. Ask your administrator to enable an approval category as "Overtime Category".
            </div>
            <div t-if="categories" class="alert alert-info" role="status">
                Once approved by your manager, this request unlocks one overtime check-in session. The requested hours become the maximum allowed duration for that overtime session.
            </div>
            <form t-if="categories" action="/my/overtime_approvals/new" method="post" class="o_portal_wrap">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="mb-3">
                    <label class="form-label" for="category_id">Approval type</label>
                    <select class="form-select" name="category_id" id="category_id" required="required">
                        <option value="" disabled="disabled" selected="selected">Choose…</option>
                        <t t-foreach="categories" t-as="cat">
                            <option t-att-value="cat.id" t-out="cat.name"/>
                        </t>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="name">Subject (optional)</label>
                    <input type="text" class="form-control" name="name" id="name" placeholder="e.g. Overtime for project rollout"/>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="overtime_date_from">From</label>
                        <input type="date" class="form-control" name="overtime_date_from" id="overtime_date_from" required="required"/>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="overtime_date_to">To</label>
                        <input type="date" class="form-control" name="overtime_date_to" id="overtime_date_to" required="required"/>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="quantity">Requested overtime hours</label>
                    <input type="number" class="form-control" name="quantity" id="quantity" step="0.01" min="0.01" required="required"/>
                </div>
                <button type="submit" class="btn btn-primary">Save draft</button>
            </form>
        </t>
    </template>

    <template id="portal_overtime_detail" name="Overtime portal: detail">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Overtime approval</t>
            </t>
            <div class="mb-3">
                <a href="/my/overtime_approvals" class="btn btn-link">Back to list</a>
            </div>
            <div t-if="success_message" class="alert alert-success" role="status">
                <span t-out="success_message"/>
            </div>
            <div t-if="error_message" class="alert alert-danger" role="alert">
                <span t-out="error_message"/>
            </div>
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title" t-field="approval.name"/>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8"><span t-field="approval.category_id"/></dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8"><span t-field="approval.request_status"/></dd>
                        <dt class="col-sm-4">Period</dt>
                        <dd class="col-sm-8">
                            <span t-field="approval.overtime_date_from"/> —
                            <span t-field="approval.overtime_date_to"/>
                        </dd>
                        <dt class="col-sm-4">Requested hours</dt>
                        <dd class="col-sm-8"><span t-field="approval.quantity"/></dd>
                        <dt class="col-sm-4">Matched overtime (hours)</dt>
                        <dd class="col-sm-8"><span t-field="approval.overtime_total_hours"/></dd>
                        <dt class="col-sm-4" t-if="approval.overtime_preauthorization">Authorization status</dt>
                        <dd class="col-sm-8" t-if="approval.overtime_preauthorization"><span t-field="approval.overtime_authorization_state"/></dd>
                    </dl>
                </div>
            </div>
            <div t-if="approval.overtime_line_ids" class="mb-3">
                <h6>Extra hours lines</h6>
                <t t-call="portal.portal_table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th class="text-end">Duration</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="approval.overtime_line_ids" t-as="line">
                            <td><span t-field="line.date"/></td>
                            <td class="text-end"><span t-field="line.manual_duration"/></td>
                            <td><span t-field="line.status"/></td>
                        </tr>
                    </tbody>
                </t>
            </div>
            <form t-if="approval.request_status == 'new'" t-attf-action="/my/overtime_approvals/{{ approval.id }}/submit" method="post" class="d-inline">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <button type="submit" class="btn btn-primary">Submit to manager</button>
            </form>
        </t>
    </template>
</cycom>
